* text=auto

# 证据哈希绑定原始字节；跨平台 checkout 必须保持统一 LF。
*.json text eol=lf
*.jsonl text eol=lf
*.md text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.in text eol=lf
*.lock text eol=lf

# 机器签名 Fixture 绑定原始现场字节，禁止 Git 在检出时改写换行符。
tests/fixtures/m3a_verified_run/** -text -diff
