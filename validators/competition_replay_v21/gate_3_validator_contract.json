{
  "schema_version": "1.0.0",
  "validator_path": "validators/competition_replay_v21/validate.py",
  "validator_sha256": "a05966419566bc038167b648a2bd7576278394b8359ca158bb547f746ed19709",
  "supported_check_ids": [
    "objective_recomputation",
    "constraint_residual",
    "decision_output_consistency",
    "variable_domain",
    "solver_status"
  ],
  "report_schema_path": "validators/competition_replay_v21/report.schema.json",
  "report_schema_sha256": "78f23aa003286d7016c20c01d73d1c754285129e9092198d6f04ae8e2cb7afc1",
  "required_observations": {
    "objective_recomputation": ["reported_objective", "recomputed_objective", "absolute_error"],
    "constraint_residual": ["max_constraint_residual"],
    "decision_output_consistency": ["decision_output_match"],
    "variable_domain": ["max_domain_violation"],
    "solver_status": ["solver_exit_code"]
  },
  "check_types": {
    "objective_recomputation": "independent_recomputation",
    "constraint_residual": "constraint_residual",
    "decision_output_consistency": "decision_output_consistency",
    "variable_domain": "variable_domain",
    "solver_status": "solver_status"
  },
  "observation_rules": {
    "objective_recomputation": {
      "reported_objective": {"comparison": "ge", "threshold": 0.0},
      "recomputed_objective": {"comparison": "ge", "threshold": 0.0},
      "absolute_error": {"comparison": "le", "threshold": 0.0001}
    },
    "constraint_residual": {
      "max_constraint_residual": {"comparison": "le", "threshold": 0.000001}
    },
    "decision_output_consistency": {
      "decision_output_match": {"comparison": "eq", "threshold": 1.0}
    },
    "variable_domain": {
      "max_domain_violation": {"comparison": "le", "threshold": 0.000001}
    },
    "solver_status": {
      "solver_exit_code": {"comparison": "eq", "threshold": 0.0}
    }
  },
  "required_input_roles": {
    "problem_data": {"min_items": 1, "max_items": 1},
    "candidate_solution": {"min_items": 3, "max_items": 3},
    "model_parameters": {"min_items": 3, "max_items": 3},
    "solver_log": {"min_items": 3, "max_items": 3}
  },
  "exact_input_set": true,
  "timeout_seconds": 30.0
}
