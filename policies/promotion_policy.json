{
  "policy_version": "1.3.0",
  "description": "Patch 晋级资格的机器可读统一策略。任何自动检查只能给出资格结论，不得自动修改 patch_index 状态。Schema 记录事实，policy 负责判定——两者不混。",
  "automatic_status_update_allowed": false,
  "diagnosis_schema_requirements": {
    "minimum_schema_version": "2.0.0",
    "legacy_evidence_cutoff": "2026-07-10T18:00:00+08:00",
    "legacy_evidence_allowlist": [
      "nc_A092_2016C_20260710_01",
      "nc_A127_2024B_20260710_02"
    ],
    "legacy_evidence_paths": {
      "nc_A092_2016C_20260710_01": {
        "baseline_run": "output/negative_controls/real/A092/nc_A092_2016C_20260710_01/baseline",
        "treatment_run": "output/negative_controls/real/A092/nc_A092_2016C_20260710_01/treatment",
        "comparison_review": "output/negative_controls/real/A092/nc_A092_2016C_20260710_01/comparison_review.json"
      },
      "nc_A127_2024B_20260710_02": {
        "baseline_run": "output/negative_controls/real/A127/nc_A127_2024B_20260710_02/baseline",
        "treatment_run": "output/negative_controls/real/A127/nc_A127_2024B_20260710_02/treatment",
        "comparison_review": "output/negative_controls/real/A127/nc_A127_2024B_20260710_02/comparison_review.json"
      }
    },
    "note": "仅 allowlist 中、截止时间前生成且路径未变的历史 A092/A127 证据可标记为 legacy_v1_grandfathered；其他晋级证据必须使用 diagnosis v2+ 并提供完整 AI 元数据与证据清单。"
  },
  "status_rules": {
    "candidate": {
      "description": "单篇论文经验化为 patch，未经旧题闭环验证",
      "required_controls": [],
      "required_result": "any",
      "min_distinct_cases": 0,
      "min_distinct_years": 0,
      "mechanism_scope": "patch",
      "min_distinct_mechanisms": 0,
      "forbidden_failure_labels": [
        "P3",
        "P4",
        "P5"
      ],
      "forbidden_material_risks": [
        "M1",
        "M2",
        "M3",
        "M5"
      ],
      "negative_control": {
        "requires_case": false,
        "requires_structured_evidence": false,
        "required_evidence_fields": []
      }
    },
    "verified_candidate": {
      "description": "至少正向+边界+负控各一次通过，且三道独立考题",
      "required_controls": [
        "positive",
        "boundary",
        "negative"
      ],
      "required_result": "pass",
      "min_distinct_cases": 3,
      "min_distinct_years": 2,
      "positive_negative_must_differ": true,
      "positive_boundary_must_differ": true,
      "negative_must_be_out_of_scope": true,
      "mechanism_scope": "patch",
      "min_distinct_mechanisms": 2,
      "forbidden_failure_labels": [
        "P3",
        "P4",
        "P5"
      ],
      "forbidden_material_risks": [
        "M1",
        "M2",
        "M3",
        "M5"
      ],
      "negative_control": {
        "requires_case": true,
        "requires_structured_evidence": true,
        "required_evidence_fields": [
          "baseline_run",
          "treatment_run",
          "comparison_review"
        ]
      },
      "repetition": {
        "min_negative_control_runs": 1,
        "note": "当前最低要求 1 次；建议至少 baseline×2 + treatment×3 以评估随机波动"
      }
    },
    "stable": {
      "description": "多年份、多机制、失败修复重测且比赛验证通过，人工最终确认",
      "required_controls": [
        "positive",
        "boundary",
        "negative"
      ],
      "required_result": "pass",
      "min_distinct_cases": 3,
      "min_distinct_years": 2,
      "positive_negative_must_differ": true,
      "positive_boundary_must_differ": true,
      "negative_must_be_out_of_scope": true,
      "mechanism_scope": "patch",
      "min_distinct_mechanisms": 3,
      "requires_failure_fix_retest": true,
      "requires_competition_verified": true,
      "requires_human_approval": true,
      "forbidden_failure_labels": [
        "P3",
        "P4",
        "P5"
      ],
      "forbidden_material_risks": [
        "M1",
        "M2",
        "M3",
        "M5"
      ],
      "negative_control": {
        "requires_case": true,
        "requires_structured_evidence": true,
        "required_evidence_fields": [
          "baseline_run",
          "treatment_run",
          "comparison_review"
        ]
      },
      "repetition": {
        "min_negative_control_runs": 2,
        "note": "stable 要求至少 2 次独立负控运行以降低随机性误判"
      },
      "stable_evidence": {
        "required": true,
        "requires_patch_level_competition_record": true,
        "requires_digest_bound_human_approval": true
      }
    }
  },
  "run_evidence_requirements": {
    "eligible_for_promotion": true,
    "evidence_validity": "real_ai_run",
    "request_source": "real_ai_run",
    "automatic_evaluation_result": "pass",
    "required_run_files": [
      "run_manifest.json",
      "problem_manifest.json",
      "runtime_pack.manifest.json",
      "runtime_pack.md",
      "request.json",
      "response.json",
      "automatic_evaluation.json",
      "ai_run_metadata.json",
      "human_review.md",
      "run_evidence_manifest.json",
      "transitions.jsonl"
    ],
    "ai_run_metadata_checks": {
      "schema": "schemas/ai_run_metadata.schema.json",
      "metadata_version_minimum": "1.0.0",
      "require_non_empty_model": true,
      "require_non_empty_provider": true,
      "require_started_at_iso8601": true,
      "require_prompt_sha256_match": true,
      "require_runtime_pack_sha256_match": true,
      "require_problem_material_digest_match": true,
      "reject_completed_before_started": true,
      "reject_absolute_paths_in_note": true,
      "baseline_treatment_must_match": [
        "provider",
        "model",
        "model_snapshot",
        "reasoning_effort",
        "client",
        "client_version",
        "temperature",
        "seed",
        "tool_permissions",
        "working_directory_mode"
      ],
      "run_evidence_manifest_schema": "schemas/run_evidence_manifest.schema.json",
      "required_artifacts": {
        "run_manifest": "run_manifest.json",
        "request": "request.json",
        "model_response": "response.json",
        "runtime_pack": "runtime_pack.md",
        "runtime_pack_manifest": "runtime_pack.manifest.json",
        "problem_manifest": "problem_manifest.json",
        "automatic_evaluation": "automatic_evaluation.json",
        "ai_run_metadata": "ai_run_metadata.json",
        "human_review": "human_review.md",
        "transitions": "transitions.jsonl"
      }
    }
  },
  "manual_controls": {
    "human_review_required": true,
    "comparison_review_schema": "schemas/comparison_review.schema.json",
    "promotion_decision_requires_human_confirmation": true,
    "note": "comparison_review 记录事实（final_result 可为 pass/fail/invalid/needs_retest）；晋级由本 policy 判定（仅 final_result==pass 且所有 risk_flags==false 且 consistency_checks 满足）"
  },
  "case_metadata": {
    "description": "矩阵中每个 case 应附带结构化元数据，不再从题号字符串推断。",
    "required_fields": [
      "problem_id",
      "year",
      "mechanism_class",
      "relation_to_patch",
      "material_level"
    ],
    "relation_to_patch_values": [
      "positive_in_scope",
      "boundary_edge_scope",
      "negative_out_of_scope"
    ]
  }
}
