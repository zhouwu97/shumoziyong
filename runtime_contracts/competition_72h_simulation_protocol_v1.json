  "state": "preregistered",
  "source_lifecycle": "blind_review_passed",
  "maximum_elapsed_hours": 72,
  "maximum_audit_overhead_ratio": 0.25,
  "required_stages": [
    "problem_selection",
    "material_ingestion",
    "modeling",
    "code_execution",
    "figure_generation",
    "paper_completion",
    "submission_artifacts",
    "final_validation"
  ],
  "required_artifacts": [
    "paper_pdf",
    "final_excel",
    "appendix",
    "submission_bundle",
    "final_validation_report"
  ],
  "human_authority": {
    "final_validation_required": true,
    "signature_required": true,
    "ai_recording_allowed": true,
    "ai_decision_authority": false
