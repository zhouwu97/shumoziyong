{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/operability_contract.schema.json",
  "title": "方案可执行性检查合同",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "subproblem_id",
    "model_route_v3_sha256",
    "selected_route_id",
    "fail_closed",
    "repair_revalidation_required",
    "checks"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "operability_contract_v1"},
    "run_id": {"type": "string", "minLength": 1},
    "subproblem_id": {"type": "string", "minLength": 1},
    "model_route_v3_sha256": {"$ref": "#/$defs/sha256"},
    "selected_route_id": {"type": "string", "pattern": "^R-[A-Z0-9_-]+$"},
    "fail_closed": {"const": true},
    "repair_revalidation_required": {"const": true},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "category",
          "strength",
          "statement",
          "measurement",
          "acceptance_rule",
          "source_ref"
        ],
        "properties": {
          "check_id": {"type": "string", "pattern": "^OP-[A-Z0-9_-]+$"},
          "category": {
            "enum": [
              "integrality",
              "minimum_order",
              "continuity",
              "capacity",
              "transport_split",
              "schedule",
              "resource",
              "business_rule",
              "physical_rule"
            ]
          },
          "strength": {"enum": ["hard", "soft"]},
          "statement": {"type": "string", "minLength": 5},
          "measurement": {"type": "string", "minLength": 3},
          "acceptance_rule": {"type": "string", "minLength": 3},
          "source_ref": {"type": "string", "minLength": 3}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
