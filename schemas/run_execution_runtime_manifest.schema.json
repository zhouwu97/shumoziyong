{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/run_execution_runtime_manifest.schema.json",
  "title": "Run Execution Python Runtime Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "python_version", "python_executable_path",
    "requirements_lock_sha256", "files"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "run_execution_runtime_manifest"},
    "python_version": {"type": "string", "minLength": 1},
    "python_executable_path": {"type": "string", "pattern": "^[A-Za-z0-9._/-]+\\.exe$"},
    "requirements_lock_sha256": {"$ref": "#/$defs/sha256"},
    "files": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
