{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gate 5 最终审核记录 v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "review_id", "review_type", "policy_version", "attempt",
    "run_id", "problem_id", "profile", "runtime_version", "runtime_pack_sha256",
    "candidate_id", "candidate_manifest_sha256", "candidate_binding_version", "reviewer", "reviewed_at",
    "decision", "reason", "checklist", "issues", "required_actions", "claim_restrictions",
    "required_limitations", "restriction_closure_refs", "requested_revision_scope", "supporting_reviews"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "artifact_type": {"const": "gate_5_review"},
    "review_id": {"type": "string", "pattern": "^G5R-[A-Za-z0-9_-]{8,120}$"},
    "review_type": {"const": "final_decision"},
    "policy_version": {"enum": ["recording_only_v1", "technical_required_v1", "human_final_technical_required_v1", "technical_and_reader_required_v1"]},
    "attempt": {"type": "integer", "minimum": 1},
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "runtime_version": {"type": "string", "minLength": 1},
    "runtime_pack_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "candidate_id": {"type": "string", "minLength": 1},
    "candidate_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "candidate_binding_version": {"enum": ["fixed_gate4_v1", "versioned_candidate_v2"]},
    "reviewer": {
      "type": "object", "additionalProperties": false, "required": ["type", "identity", "session_id"],
      "properties": {"type": {"enum": ["human", "independent_llm"]}, "identity": {"type": "string", "minLength": 1}, "session_id": {"type": ["string", "null"]}}
    },
    "reviewed_at": {"type": "string", "format": "date-time"},
    "decision": {"enum": ["approved", "needs_revision", "rejected"]},
    "reason": {"type": "string", "minLength": 10},
    "checklist": {
      "type": "object", "additionalProperties": false,
      "required": ["materials", "diagnosis", "model_route", "code_reproduction", "results", "claim_evidence", "risk_closure", "final_acceptance"],
      "additionalProperties": false,
      "patternProperties": {"^(materials|diagnosis|model_route|code_reproduction|results|claim_evidence|risk_closure|final_acceptance)$": {"$ref": "#/$defs/check_item"}}
    },
    "issues": {"type": "array", "items": {"$ref": "#/$defs/issue"}},
    "required_actions": {"type": "array", "items": {"$ref": "#/$defs/action"}},
    "claim_restrictions": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_limitations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "restriction_closure_refs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
    "requested_revision_scope": {"enum": ["paper_candidate", "model_route", "formal_result", "diagnosis", "terminal_rejection", null]},
    "supporting_reviews": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["review_id", "path", "sha256", "decision", "candidate_id", "candidate_manifest_sha256"], "properties": {"review_id": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "decision": {"enum": ["approved", "needs_revision", "rejected"]}, "candidate_id": {"type": "string", "minLength": 1}, "candidate_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}}
  },
  "$defs": {
    "check_item": {"type": "object", "additionalProperties": false, "required": ["status", "reason", "evidence_refs"], "properties": {"status": {"enum": ["passed", "failed", "not_applicable"]}, "reason": {"type": "string", "minLength": 1}, "evidence_refs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}}}},
    "issue": {"type": "object", "additionalProperties": false, "required": ["issue_id", "severity", "category", "description", "evidence_refs"], "properties": {"issue_id": {"type": "string", "minLength": 1}, "severity": {"enum": ["blocking", "major", "minor"]}, "category": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "evidence_refs": {"type": "array", "items": {"type": "object"}}}},
    "action": {"type": "object", "additionalProperties": false, "required": ["action_id", "description", "acceptance_criteria"], "properties": {"action_id": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "acceptance_criteria": {"type": "string", "minLength": 1}}}
  }
}
