{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_rhetoric_bundle.schema.json",
  "title": "版本化表达卡片包",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "bundle_id", "content_sha256", "status", "cards",
    "compatible_planner_versions", "compatible_validator_versions", "qualification_evidence",
    "production_allowed"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "paper_rhetoric_bundle"},
    "bundle_id": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "status": {"enum": ["prototype", "qualification_candidate", "exploratory_review_passed", "confirmatory_review_passed", "production_ready"]},
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["card_id", "path", "sha256"],
        "properties": {
          "card_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "compatible_planner_versions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "compatible_validator_versions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "qualification_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "production_allowed": {"type": "boolean"}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "production_ready"}}, "required": ["status"]},
      "then": {"properties": {"production_allowed": {"const": true}}},
      "else": {"properties": {"production_allowed": {"const": false}}}
    }
  ]
}
