{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/sandboxie_run_execution_attestation.schema.json",
  "title": "Sandboxie Run 专属执行证明 v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attestation_version", "artifact_type", "run_id", "formal_result_id", "execution_id",
    "execution_spec_sha256", "run_manifest_sha256", "code_manifest_sha256",
    "input_manifest_sha256", "output_manifest_sha256", "execution_record_sha256",
    "formal_result_payload_manifest_sha256", "collector_derivation_attestation_sha256",
    "formal_result_core_digest",
    "environment_report_sha256", "environment_attestation_sha256",
    "trusted_registry_sha256", "trusted_key_entry_semantic_sha256", "environment_fingerprint",
    "start_exe_sha256", "sandboxie_box_name", "sandbox_policy_sha256", "launch_command_sha256",
    "execution_trust_model", "git_head", "git_state_clean",
    "privacy_mode_available", "targeted_host_read_controls_passed",
    "default_deny_host_reads_verified", "started_at",
    "completed_at", "challenge_nonce", "exit_code", "stdout_sha256", "stderr_sha256",
    "machine_key_id", "signature_algorithm", "signature"
  ],
  "properties": {
    "attestation_version": {"const": "1.0.0"},
    "artifact_type": {"const": "sandboxie_run_execution_attestation"},
    "run_id": {"type": "string", "minLength": 1},
    "formal_result_id": {"type": "string", "minLength": 1},
    "execution_id": {"type": "string", "pattern": "^sandboxie-exec-[A-Za-z0-9._-]{8,96}$"},
    "execution_spec_sha256": {"$ref": "#/$defs/sha256"},
    "run_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "code_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "input_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "output_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "execution_record_sha256": {"$ref": "#/$defs/sha256"},
    "formal_result_payload_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "collector_derivation_attestation_sha256": {"$ref": "#/$defs/sha256"},
    "formal_result_core_digest": {"$ref": "#/$defs/sha256"},
    "environment_report_sha256": {"$ref": "#/$defs/sha256"},
    "environment_attestation_sha256": {"$ref": "#/$defs/sha256"},
    "trusted_registry_sha256": {"$ref": "#/$defs/sha256"},
    "trusted_key_entry_semantic_sha256": {"$ref": "#/$defs/sha256"},
    "environment_fingerprint": {"$ref": "#/$defs/sha256"},
    "start_exe_sha256": {"$ref": "#/$defs/sha256"},
    "sandboxie_box_name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]{3,63}$"},
    "sandbox_policy_sha256": {"$ref": "#/$defs/sha256"},
    "launch_command_sha256": {"$ref": "#/$defs/sha256"},
    "execution_trust_model": {"const": "trusted_local"},
    "git_head": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "git_state_clean": {"const": true},
    "privacy_mode_available": {"type": "boolean"},
    "targeted_host_read_controls_passed": {"const": true},
    "default_deny_host_reads_verified": {"const": false},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "challenge_nonce": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "exit_code": {"const": 0},
    "stdout_sha256": {"$ref": "#/$defs/sha256"},
    "stderr_sha256": {"$ref": "#/$defs/sha256"},
    "machine_key_id": {"type": "string", "pattern": "^sandboxie-host-[a-f0-9]{16}$"},
    "signature_algorithm": {"const": "RSASSA-PKCS1-v1_5-SHA256"},
    "signature": {"type": "string", "pattern": "^[A-Za-z0-9+/]+={0,2}$", "minLength": 128}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
