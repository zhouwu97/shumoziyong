{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/collector_attestation.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "problem_id", "profile", "runtime_version", "runtime_pack_sha256", "formal_result_policy", "execution_contract_version", "formal_result_contract_version", "canonicalization_version", "gate_artifact_contract_version", "formal_result_id", "collector_id", "collector_version", "source_commit", "input_manifest_sha256", "code_manifest_sha256", "execution_spec_sha256", "environment_manifest_sha256", "sandbox_policy", "candidate_access_assurance", "candidate_output_access_not_detected", "started_at", "completed_at", "exit_code", "stdout_sha256", "stderr_sha256", "output_file_set", "undeclared_write_check", "negative_test_report_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "collector_attestation"},
    "run_id": {"$ref": "#/$defs/id"}, "problem_id": {"$ref": "#/$defs/id"}, "profile": {"$ref": "#/$defs/id"}, "runtime_version": {"$ref": "#/$defs/id"},
    "runtime_pack_sha256": {"$ref": "#/$defs/sha"}, "formal_result_policy": {"const": "required_v1"},
    "execution_contract_version": {"const": "1.0.0"}, "formal_result_contract_version": {"const": "1.0.0"}, "canonicalization_version": {"const": "1.0.0"}, "gate_artifact_contract_version": {"const": "1.0.0"},
    "formal_result_id": {"$ref": "#/$defs/id"}, "collector_id": {"$ref": "#/$defs/id"}, "collector_version": {"$ref": "#/$defs/id"},
    "source_commit": {"type": "string", "pattern": "^[a-f0-9]{7,40}$"},
    "input_manifest_sha256": {"$ref": "#/$defs/sha"}, "code_manifest_sha256": {"$ref": "#/$defs/sha"}, "execution_spec_sha256": {"$ref": "#/$defs/sha"}, "environment_manifest_sha256": {"$ref": "#/$defs/sha"},
    "sandbox_policy": {"type": "string", "minLength": 1}, "candidate_access_assurance": {"const": "manifest_isolation"}, "candidate_output_access_not_detected": {"type": "boolean"},
    "started_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"}, "exit_code": {"const": 0},
    "stdout_sha256": {"$ref": "#/$defs/sha"}, "stderr_sha256": {"$ref": "#/$defs/sha"},
    "output_file_set": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "undeclared_write_check": {"const": "passed"}, "negative_test_report_sha256": {"$ref": "#/$defs/sha"}
  },
  "$defs": {"id": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
