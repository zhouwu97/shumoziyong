{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/formal_result_manifest.schema.json",
  "title": "正式结果清单 v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "schema_version", "scope", "formal_result_id", "collector_run_id", "task_id", "execution_spec_sha256", "material_manifest_sha256", "source_material_hashes", "data_extraction_contract_sha256", "model_route_sha256", "code_commit", "code_tree_sha256", "environment_sha256", "validator_sha256", "collector_command", "solver", "tie_break_policy", "decision_output", "decision_variables_hash", "metrics", "validation", "recomputed_objective", "reported_objective", "objective_difference", "max_capacity_residual", "domain_violations", "illegal_combinations", "validation_status", "stdout_hash", "stderr_hash", "canonicalization_version", "created_by", "candidate_output_used"],
  "properties": {
    "contract_version": {"const": "formal_result_v1"},
    "schema_version": {"const": "1.0.0"},
    "scope": {"const": "2024-C-Q1-single-season-dryland-baseline"},
    "formal_result_id": {"type": "string", "minLength": 1},
    "collector_run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "execution_spec_sha256": {"$ref": "#/$defs/sha256"},
    "material_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "source_material_hashes": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/sha256"}},
    "data_extraction_contract_sha256": {"$ref": "#/$defs/sha256"},
    "model_route_sha256": {"$ref": "#/$defs/sha256"},
    "code_commit": {"type": "string", "pattern": "^[a-f0-9]{7,40}$"},
    "code_tree_sha256": {"$ref": "#/$defs/sha256"},
    "environment_sha256": {"$ref": "#/$defs/sha256"},
    "validator_sha256": {"$ref": "#/$defs/sha256"},
    "collector_command": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "solver": {"type": "object", "additionalProperties": false, "required": ["name", "version", "status"], "properties": {"name": {"type": "string", "minLength": 1}, "version": {"type": "string", "minLength": 1}, "status": {"enum": ["optimal", "feasible"]}}},
    "tie_break_policy": {"const": "lexicographic_plot_crop_v1"},
    "decision_output": {"$ref": "#/$defs/file"},
    "decision_variables_hash": {"$ref": "#/$defs/sha256"},
    "metrics": {"type": "object", "minProperties": 1, "additionalProperties": {"type": ["number", "boolean", "string"]}},
    "validation": {"$ref": "#/$defs/file"},
    "recomputed_objective": {"type": "number"},
    "reported_objective": {"type": "number"},
    "objective_difference": {"type": "number", "minimum": 0},
    "max_capacity_residual": {"type": "number", "minimum": 0},
    "domain_violations": {"type": "integer", "minimum": 0},
    "illegal_combinations": {"type": "integer", "minimum": 0},
    "validation_status": {"const": "passed"},
    "stdout_hash": {"$ref": "#/$defs/sha256"},
    "stderr_hash": {"$ref": "#/$defs/sha256"},
    "canonicalization_version": {"const": "1.0.0"},
    "created_by": {"const": "collector"},
    "candidate_output_used": {"const": false}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "file": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}}}
}
