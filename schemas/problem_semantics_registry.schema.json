{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/problem_semantics_registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "registry_id", "problems", "required_section_aliases",
    "forbidden_generic_formulas"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "registry_id": {"const": "problem_semantics_registry_v1"},
    "problems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["problem_id", "subproblem_ids", "required_entities", "forbidden_entities"],
        "properties": {
          "problem_id": {"type": "string", "minLength": 1},
          "subproblem_ids": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "pattern": "^Q[1-9][0-9]*$"}
          },
          "required_entities": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "forbidden_entities": {
            "type": "array", "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "required_section_aliases": {
      "type": "object",
      "minProperties": 9,
      "additionalProperties": {
        "type": "array", "minItems": 1, "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      }
    },
    "forbidden_generic_formulas": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
