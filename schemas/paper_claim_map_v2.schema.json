{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_claim_map_v2.schema.json",
  "title": "Claim-Evidence Map v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "problem_id", "claims"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "artifact_type": {"const": "paper_claim_map_v2"},
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "claims": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["claim_id", "claim", "scope", "result_refs", "evidence_refs", "status"],
        "properties": {
          "claim_id": {"type": "string", "pattern": "^C[0-9]{3,}$"},
          "claim": {"type": "string", "minLength": 10},
          "scope": {"type": "string", "minLength": 10},
          "result_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "figure_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "manuscript_locations": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "status": {"enum": ["supported", "needs_evidence", "bounded_inference"]}
        }
      }
    }
  }
}
