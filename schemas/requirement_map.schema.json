{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/requirement_map.schema.json",
  "title": "原子需求映射 v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "problem_id", "source_core_fragment_ids", "requirements"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "atomic_requirement_map_v1"},
    "problem_id": {"type": "string", "minLength": 1},
    "source_core_fragment_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+$"}},
    "requirements": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "#/$defs/requirement"}
    }
  },
  "$defs": {
    "sourceAnchor": {
      "type": "object", "additionalProperties": false,
      "required": ["document_id", "page", "clause_label", "normalized_excerpt", "normalized_excerpt_sha256"],
      "properties": {
        "document_id": {"type": "string", "minLength": 1},
        "page": {"type": "integer", "minimum": 1},
        "clause_label": {"type": "string", "minLength": 1},
        "normalized_excerpt": {"type": "string", "minLength": 1},
        "normalized_excerpt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "binding": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "artifact", "required"],
      "properties": {
        "mode": {"enum": ["numerical_validator", "analytic_reference", "reference_oracle", "metamorphic_property", "schema_validation", "artifact_validation", "paper_consistency_review", "human_technical_review"]},
        "artifact": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"}
      }
    },
    "requirement": {
      "type": "object", "additionalProperties": false,
      "required": ["requirement_id", "question", "requirement_type", "criticality", "source_anchor", "verification_bindings"],
      "properties": {
        "requirement_id": {"type": "string", "pattern": "^REQ-[A-Z0-9-]+$"},
        "question": {"enum": ["GENERAL", "Q1", "Q2", "Q3", "Q4"]},
        "requirement_type": {"enum": ["mathematical_derivation", "numerical_result", "decision_design", "data_processing", "explanation", "comparison", "recommendation", "artifact_output", "format_constraint"]},
        "criticality": {"enum": ["core", "supporting"]},
        "source_anchor": {"$ref": "#/$defs/sourceAnchor"},
        "verification_bindings": {"type": "array", "items": {"$ref": "#/$defs/binding"}}
      }
    }
  }
}
