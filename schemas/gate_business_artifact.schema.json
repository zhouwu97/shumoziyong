{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/gate_business_artifact.schema.json",
  "title": "Gate 0-4 业务产物",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "problem_id",
    "profile",
    "runtime_version",
    "runtime_pack_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {
      "enum": [
        "diagnosis",
        "model_route",
        "code_plan",
        "result_report",
        "result_manifest",
        "paper_claim_map"
      ]
    },
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "runtime_version": {"type": "string", "minLength": 1},
    "runtime_pack_sha256": {"$ref": "#/$defs/sha256"}
  },
  "oneOf": [
    {
      "properties": {
        "artifact_type": {"const": "diagnosis"},
        "problem_summary": {"type": "string", "minLength": 20},
        "material_findings": {"$ref": "#/$defs/nonEmptyStrings"},
        "objectives": {"$ref": "#/$defs/nonEmptyStrings"},
        "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "risks": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["problem_summary", "material_findings", "objectives", "constraints", "risks"]
    },
    {
      "properties": {
        "artifact_type": {"const": "model_route"},
        "selected_route": {"type": "string", "minLength": 10},
        "alternatives": {"$ref": "#/$defs/nonEmptyStrings"},
        "assumptions": {"$ref": "#/$defs/nonEmptyStrings"},
        "validation_plan": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["selected_route", "alternatives", "assumptions", "validation_plan"]
    },
    {
      "properties": {
        "artifact_type": {"const": "code_plan"},
        "commands": {"$ref": "#/$defs/nonEmptyStrings"},
        "modules": {"$ref": "#/$defs/nonEmptyStrings"},
        "inputs": {"$ref": "#/$defs/nonEmptyStrings"},
        "outputs": {"$ref": "#/$defs/nonEmptyStrings"},
        "verification_steps": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["commands", "modules", "inputs", "outputs", "verification_steps"]
    },
    {
      "properties": {
        "artifact_type": {"const": "result_report"},
        "conclusions": {"$ref": "#/$defs/nonEmptyStrings"},
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "source"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "value": {"type": ["number", "string", "boolean"]},
              "unit": {"type": ["string", "null"]},
              "source": {"type": "string", "minLength": 1}
            }
          }
        },
        "limitations": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["conclusions", "metrics", "limitations"]
    },
    {
      "properties": {
        "artifact_type": {"const": "result_manifest"},
        "executions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "exit_code", "outputs"],
            "properties": {
              "command": {"type": "string", "minLength": 1},
              "exit_code": {"const": 0},
              "outputs": {"$ref": "#/$defs/hashedFiles"}
            }
          }
        },
        "inputs": {"$ref": "#/$defs/hashedFiles"},
        "outputs": {"$ref": "#/$defs/hashedFiles"}
      },
      "required": ["executions", "inputs", "outputs"]
    },
    {
      "properties": {
        "artifact_type": {"const": "paper_claim_map"},
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["claim_id", "claim", "result_refs", "evidence_refs"],
            "properties": {
              "claim_id": {"type": "string", "pattern": "^C[0-9]{3,}$"},
              "claim": {"type": "string", "minLength": 10},
              "result_refs": {"$ref": "#/$defs/nonEmptyStrings"},
              "evidence_refs": {"$ref": "#/$defs/nonEmptyStrings"}
            }
          }
        }
      },
      "required": ["claims"]
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "hashedFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  }
}
