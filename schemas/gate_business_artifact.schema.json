{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/gate_business_artifact.schema.json",
  "title": "Gate 0-4 业务产物",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "problem_id",
    "profile",
    "runtime_version",
    "runtime_pack_sha256"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {
      "enum": [
        "diagnosis",
        "model_route",
        "code_plan",
        "result_report",
        "result_manifest",
        "paper_claim_map"
      ]
    },
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "runtime_version": {"type": "string", "minLength": 1},
    "runtime_pack_sha256": {"$ref": "#/$defs/sha256"}
  },
  "oneOf": [
    {
      "properties": {
        "artifact_type": {"const": "diagnosis"},
        "problem_summary": {"type": "string", "minLength": 20},
        "material_findings": {"$ref": "#/$defs/nonEmptyStrings"},
        "objectives": {"$ref": "#/$defs/nonEmptyStrings"},
        "constraints": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "risks": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["problem_summary", "material_findings", "objectives", "constraints", "risks"]
    },
    {
      "properties": {
        "artifact_type": {"const": "model_route"},
        "selected_route": {"type": "string", "minLength": 10},
        "alternatives": {"$ref": "#/$defs/nonEmptyStrings"},
        "assumptions": {"$ref": "#/$defs/nonEmptyStrings"},
        "validation_plan": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["selected_route", "alternatives", "assumptions", "validation_plan"]
    },
    {
      "properties": {
        "artifact_type": {"const": "code_plan"},
        "commands": {"$ref": "#/$defs/nonEmptyStrings"},
        "modules": {"$ref": "#/$defs/nonEmptyStrings"},
        "inputs": {"$ref": "#/$defs/nonEmptyStrings"},
        "outputs": {"$ref": "#/$defs/nonEmptyStrings"},
        "verification_steps": {"$ref": "#/$defs/nonEmptyStrings"}
      },
      "required": ["commands", "modules", "inputs", "outputs", "verification_steps"]
    },
    {
      "properties": {
        "artifact_type": {"const": "result_report"},
        "conclusions": {"$ref": "#/$defs/nonEmptyStrings"},
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "source"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "value": {"type": ["number", "string", "boolean"]},
              "unit": {"type": ["string", "null"]},
              "source": {"type": "string", "minLength": 1}
            }
          }
        },
        "limitations": {"$ref": "#/$defs/nonEmptyStrings"},
        "model_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model_type", "variables", "parameters", "formulas", "objectives",
            "constraints", "boundary_conditions", "unit_checks",
            "claim_result_bindings", "optimization_checks"
          ],
          "properties": {
            "model_type": {"enum": ["descriptive", "prediction", "continuous_optimization", "mip", "nonlinear_optimization", "heuristic", "simulation", "other"]},
            "variables": {"$ref": "#/$defs/symbolDefinitions"},
            "parameters": {"$ref": "#/$defs/symbolDefinitions"},
            "formulas": {
              "type": "array", "minItems": 1,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["formula_id", "expression", "symbols"],
                "properties": {
                  "formula_id": {"type": "string", "minLength": 1},
                  "expression": {"type": "string", "minLength": 1},
                  "symbols": {"$ref": "#/$defs/nonEmptyStrings"}
                }
              }
            },
            "objectives": {"$ref": "#/$defs/nonEmptyStrings"},
            "constraints": {"$ref": "#/$defs/nonEmptyStrings"},
            "boundary_conditions": {"$ref": "#/$defs/nonEmptyStrings"},
            "unit_checks": {
              "type": "array", "minItems": 1,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["expression", "compatible"],
                "properties": {
                  "expression": {"type": "string", "minLength": 1},
                  "compatible": {"type": "boolean"}
                }
              }
            },
            "claim_result_bindings": {
              "type": "array", "minItems": 1,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["claim_id", "metric"],
                "properties": {
                  "claim_id": {"type": "string", "pattern": "^C[0-9]{3,}$"},
                  "metric": {"type": "string", "minLength": 1}
                }
              }
            },
            "optimization_checks": {
              "type": "object", "additionalProperties": false,
              "required": ["configured", "passed", "not_applicable"],
              "properties": {
                "configured": {"$ref": "#/$defs/optimizationCheckNames"},
                "passed": {"$ref": "#/$defs/optimizationCheckNames"},
                "not_applicable": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["reason", "condition"],
                    "properties": {
                      "reason": {"type": "string", "minLength": 10},
                      "condition": {"type": "string", "minLength": 10}
                    }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["conclusions", "metrics", "limitations", "model_contract"]
    },
    {
      "properties": {
        "artifact_type": {"const": "result_manifest"},
        "executions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "exit_code", "outputs"],
            "properties": {
              "command": {"type": "string", "minLength": 1},
              "exit_code": {"const": 0},
              "outputs": {"$ref": "#/$defs/hashedFiles"}
            }
          }
        },
        "inputs": {"$ref": "#/$defs/hashedFiles"},
        "outputs": {"$ref": "#/$defs/hashedFiles"},
        "environment": {
          "type": "object", "additionalProperties": false,
          "required": ["python", "os", "solver", "git_sha", "dependencies"],
          "properties": {
            "python": {"type": "string", "minLength": 1},
            "os": {"type": "string", "minLength": 1},
            "solver": {"type": ["string", "null"]},
            "git_sha": {"type": "string", "pattern": "^[a-f0-9]{7,40}$"},
            "dependencies": {"$ref": "#/$defs/nonEmptyStrings"}
          }
        },
        "random_seeds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer"}},
        "tolerances": {
          "type": "object", "minProperties": 1,
          "additionalProperties": {"type": "number", "minimum": 0}
        },
        "deterministic_expected": {"type": "boolean"},
        "repeated_runs": {
          "type": "array", "minItems": 2,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": [
              "execution_id", "seed", "started_at", "completed_at", "exit_code",
              "output_sha256", "stdout_sha256", "environment_sha256"
            ],
            "properties": {
              "execution_id": {"type": "string", "minLength": 1},
              "seed": {"type": "integer"},
              "started_at": {"type": "string", "format": "date-time"},
              "completed_at": {"type": "string", "format": "date-time"},
              "exit_code": {"const": 0},
              "output_sha256": {"$ref": "#/$defs/sha256"},
              "stdout_sha256": {"$ref": "#/$defs/sha256"},
              "environment_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        }
      },
      "required": ["executions", "inputs", "outputs", "environment", "random_seeds", "tolerances", "deterministic_expected", "repeated_runs"]
    },
    {
      "properties": {
        "artifact_type": {"const": "paper_claim_map"},
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["claim_id", "claim", "result_refs", "evidence_refs"],
            "properties": {
              "claim_id": {"type": "string", "pattern": "^C[0-9]{3,}$"},
              "claim": {"type": "string", "minLength": 10},
              "result_refs": {"$ref": "#/$defs/nonEmptyStrings"},
              "evidence_refs": {"$ref": "#/$defs/nonEmptyStrings"}
            }
          }
        }
      },
      "required": ["claims"]
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "symbolDefinitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "definition", "unit", "source"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$"},
          "definition": {"type": "string", "minLength": 1},
          "unit": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1}
        }
      }
    },
    "optimizationCheckNames": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["baseline", "feasibility", "constraint_residual", "mip_gap", "kkt", "multi_start", "bounds", "sensitivity"]}
    },
    "hashedFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"$ref": "#/$defs/sha256"}
        }
      }
    }
  }
}
