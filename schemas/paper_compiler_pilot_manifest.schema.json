{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_compiler_pilot_manifest.schema.json",
  "title": "论文编译器第一阶段试点清单",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "pilot_id", "automated_status",
    "automated_scope", "qualification_status", "production_allowed",
    "validation_boundary", "review_freeze", "artifacts"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "paper_compiler_pilot_manifest"},
    "pilot_id": {"const": "paper-compiler-2024c-q1-v1.1.1"},
    "automated_status": {"enum": ["passed", "failed"]},
    "automated_scope": {"const": "paper_compiler_v1_1_1_pilot"},
    "qualification_status": {
      "enum": [
        "awaiting_external_human_review", "awaiting_human_overlap_review",
        "awaiting_adjudication", "completed", "failed_integrity"
      ]
    },
    "production_allowed": {"const": false},
    "validation_boundary": {"$ref": "#/$defs/fileBinding"},
    "review_freeze": {"$ref": "#/$defs/fileBinding"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fileBinding"}
    }
  },
  "$defs": {
    "fileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    }
  }
}
