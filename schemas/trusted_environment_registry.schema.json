{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/trusted_environment_registry.schema.json",
  "title": "可信环境机器公钥注册表 v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["registry_version", "keys"],
  "properties": {
    "registry_version": {"const": "1.0.0"},
    "keys": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["machine_key_id", "status", "signature_algorithm", "certificate_thumbprint", "subject", "issuer", "not_before", "not_after", "rsa_modulus_hex", "rsa_exponent", "allowed_probe_sha256"],
        "properties": {
          "machine_key_id": {"type": "string", "pattern": "^sandboxie-host-[a-f0-9]{16}$"},
          "status": {"enum": ["active", "revoked"]},
          "signature_algorithm": {"const": "RSASSA-PKCS1-v1_5-SHA256"},
          "certificate_thumbprint": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
          "subject": {"type": "string", "minLength": 1},
          "issuer": {"type": "string", "minLength": 1},
          "not_before": {"type": "string", "format": "date-time"},
          "not_after": {"type": "string", "format": "date-time"},
          "rsa_modulus_hex": {"type": "string", "pattern": "^[a-f0-9]{512,1024}$"},
          "rsa_exponent": {"type": "integer", "minimum": 3},
          "allowed_probe_sha256": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "uniqueItems": true}
        }
      }
    }
  }
}
