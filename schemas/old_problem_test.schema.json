{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/old_problem_test.schema.json",
  "title": "旧题测试记录",
  "type": "object",
  "additionalProperties": false,
  "required": ["test_id", "date", "problem_id", "profile", "gates", "material_level", "score", "failure_labels", "result", "evidence"],
  "properties": {
    "test_id": {"type": "string", "minLength": 1},
    "date": {"type": "string", "format": "date"},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "gates": {"enum": ["0-2", "0-5"]},
    "material_level": {"enum": ["T0", "T1", "T2", "T3", "T4"]},
    "score": {"type": "integer", "minimum": 0, "maximum": 100},
    "failure_labels": {"type": "array", "uniqueItems": true, "items": {"pattern": "^P(?:[1-9]|10)$"}},
    "result": {"enum": ["pass", "fail"]},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
