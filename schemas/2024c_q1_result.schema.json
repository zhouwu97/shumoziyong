{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/2024c_q1_result.schema.json",
  "title": "2024-C Q1 Formal Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "problem_id", "material_manifest_sha256", "scenarios"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "2024c_q1_formal_result"},
    "problem_id": {"const": "2024-C"},
    "material_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scenarios": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/scenario"}
    }
  },
  "$defs": {
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "objective_reported", "assignments", "output_workbook_status"],
      "properties": {
        "scenario_id": {"enum": ["q1_waste", "q1_discount"]},
        "objective_reported": {"type": "number"},
        "assignments": {
          "type": "array",
          "items": {"$ref": "#/$defs/assignment"}
        },
        "output_workbook_status": {"enum": ["not_yet_generated", "generated"]},
        "output_workbook_path": {"type": "string", "minLength": 1},
        "output_workbook_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "allOf": [
        {
          "if": {"properties": {"output_workbook_status": {"const": "generated"}}},
          "then": {"required": ["output_workbook_path", "output_workbook_sha256"]}
        }
      ]
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year", "plot_id", "season", "crop_id", "area_mu"],
      "properties": {
        "year": {"type": "integer", "minimum": 2024, "maximum": 2030},
        "plot_id": {"type": "string", "minLength": 1},
        "season": {"enum": ["单季", "第一季", "第二季"]},
        "crop_id": {"type": "integer", "minimum": 1, "maximum": 41},
        "area_mu": {"type": "number", "minimum": 0}
      }
    }
  }
}
