{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/prediction_collector_derivation_attestation.schema.json",
  "title": "Prediction Formal Result Collector 派生证明 v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_type", "run_id", "formal_result_id", "execution_id",
    "run_output_manifest_sha256", "result_derivation_contract", "formal_core_semantic_sha256",
    "formal_result_core_digest", "collector_id", "collector_source_commit",
    "collector_script_path", "collector_script_sha256", "derivation_contract_id",
    "derivation_contract_sha256", "domain_policy_sha256", "derived_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "collector_derivation_attestation"},
    "run_id": {"type": "string", "minLength": 1},
    "formal_result_id": {"type": "string", "minLength": 1},
    "execution_id": {"type": "string", "minLength": 1},
    "run_output_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "result_derivation_contract": {"$ref": "#/$defs/derivationContract"},
    "formal_core_semantic_sha256": {"$ref": "#/$defs/coreHashes"},
    "formal_result_core_digest": {"$ref": "#/$defs/sha256"},
    "collector_id": {"const": "m3a-json-pointer-collector-v1"},
    "collector_source_commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "collector_script_path": {"const": "scripts/run_in_verified_sandbox.py"},
    "collector_script_sha256": {"$ref": "#/$defs/sha256"},
    "derivation_contract_id": {"const": "m3a-prediction-heldout-v1"},
    "derivation_contract_sha256": {"$ref": "#/$defs/sha256"},
    "domain_policy_sha256": {"$ref": "#/$defs/sha256"},
    "derived_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "mapping": {
      "type": "object", "additionalProperties": false,
      "required": ["source_pointer", "target_artifact", "target_pointer"],
      "properties": {
        "source_pointer": {"type": "string", "pattern": "^/"},
        "target_artifact": {"enum": ["prediction_result.json", "negative_tests.json"]},
        "target_pointer": {"type": "string", "pattern": "^/"}
      }
    },
    "derivationContract": {
      "type": "object", "additionalProperties": false,
      "required": ["contract_version", "raw_output_path", "mappings"],
      "properties": {
        "contract_version": {"const": "1.0.0"},
        "raw_output_path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$))[A-Za-z0-9._/-]+\\.json$"},
        "mappings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/mapping"}}
      }
    },
    "coreHashes": {
      "type": "object", "additionalProperties": false,
      "required": ["prediction_result.json", "prediction_validation.json", "prediction_reproducibility_certificate.json", "negative_tests.json"],
      "properties": {
        "prediction_result.json": {"$ref": "#/$defs/sha256"},
        "prediction_validation.json": {"$ref": "#/$defs/sha256"},
        "prediction_reproducibility_certificate.json": {"$ref": "#/$defs/sha256"},
        "negative_tests.json": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
