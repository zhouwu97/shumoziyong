{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/competition_material_plan.schema.json",
  "title": "比赛材料准备计划",
  "description": "plan 命令唯一输出契约；Profile 与 Mode 不属于计划身份。",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_version", "problem_id", "material_root", "scanned_at", "excluded_paths", "files", "plan_digest"],
  "properties": {
    "plan_version": {"const": "1.0.0"},
    "problem_id": {"type": "string", "minLength": 1},
    "material_root": {"type": "string", "minLength": 1},
    "scanned_at": {"type": "string", "format": "date-time"},
    "excluded_paths": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "plan_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "size_bytes", "sha256", "suggested_category", "confirmed_category"],
        "properties": {
          "path": {"type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "suggested_category": {"enum": ["problem", "attachments", "templates", "unknown"]},
          "confirmed_category": {"enum": ["problem", "attachments", "templates", "unknown", null]}
        }
      }
    }
  }
}
