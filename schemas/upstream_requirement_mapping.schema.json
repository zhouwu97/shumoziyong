{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/upstream_requirement_mapping.schema.json",
  "title": "上游需求到本仓合同的映射",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mapping_registry_id",
    "source_commit",
    "adapter_authority",
    "mappings"
  ],
  "properties": {
    "schema_version": {"const": "upstream_requirement_mapping_v1"},
    "mapping_registry_id": {"const": "upstream_requirement_mapping_v1"},
    "source_commit": {"const": "be9c59c1aaa13c3dcb74452ea5cae11dada27589"},
    "adapter_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generate_results",
        "modify_paper",
        "decide_gate_pass",
        "advance_stage",
        "execute_upstream_content"
      ],
      "properties": {
        "generate_results": {"const": false},
        "modify_paper": {"const": false},
        "decide_gate_pass": {"const": false},
        "advance_stage": {"const": false},
        "execute_upstream_content": {"const": false}
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mapping_id",
          "requirement_ids",
          "target_stage",
          "target_contracts",
          "adapter_directive",
          "evidence_requests",
          "enforcement_owner"
        ],
        "properties": {
          "mapping_id": {"type": "string", "pattern": "^MAP-[A-Z0-9-]+$"},
          "requirement_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(PROD|PAPER|FIG|VER)-[0-9]{3}$"}
          },
          "target_stage": {"enum": ["diagnostic", "route", "formal_result", "paper"]},
          "target_contracts": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(schemas|checklists|runtime_contracts)/"}
          },
          "adapter_directive": {
            "enum": ["emit_diagnostic", "request_evidence", "emit_advisory"]
          },
          "evidence_requests": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 3}
          },
          "enforcement_owner": {
            "enum": ["gate_0", "gate_1", "gate_2", "gate_3", "gate_4", "gate_5"]
          }
        }
      }
    }
  }
}
