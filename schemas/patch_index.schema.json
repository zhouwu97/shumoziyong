{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/patch_index.schema.json",
  "title": "Patch 索引",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "patch_id",
      "file",
      "source",
      "problem_type",
      "keywords",
      "runtime_profiles",
      "status",
      "applicable_when",
      "misuse_risks",
      "tested_on",
      "validation_records",
      "priority"
    ],
    "properties": {
      "patch_id": {
        "type": "string",
        "pattern": "^[A-Z][0-9]{3}$"
      },
      "file": {
        "type": "string",
        "pattern": "^prompt_patches/.+\\.md$"
      },
      "source": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "paper_id",
          "title",
          "year",
          "knowledge_card",
          "claim_ids",
          "page_refs",
          "evidence_quotes"
        ],
        "properties": {
          "paper_id": {
            "type": "string",
            "pattern": "^[A-Z][0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "year": {
            "type": "integer",
            "minimum": 2000,
            "maximum": 2100
          },
          "knowledge_card": {
            "type": "string",
            "pattern": "^papers/.+\\.json$"
          },
          "claim_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[A-Z][0-9]{3}-C[0-9]{3}$"}
          },
          "page_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "evidence_quotes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "problem_type": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "keywords": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "runtime_profiles": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      },
      "status": {
        "enum": [
          "draft",
          "review_ready",
          "regression_verified",
          "competition_evidenced",
          "deprecated"
        ]
      },
      "applicable_when": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "misuse_risks": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "tested_on": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "validation_records": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "priority": {
        "type": "integer",
        "minimum": 0
      },
      "stable_evidence": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "negative_control_runs",
          "failure_fix_retests",
          "competition_validation_records",
          "human_approval_record"
        ],
        "properties": {
          "negative_control_runs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "experiment_group_id",
                "case",
                "baseline_run",
                "treatment_run",
                "comparison_review"
              ],
              "properties": {
                "experiment_group_id": {
                  "type": "string",
                  "minLength": 1
                },
                "case": {
                  "type": "string",
                  "minLength": 1
                },
                "baseline_run": {
                  "$ref": "#/$defs/relativePath"
                },
                "treatment_run": {
                  "$ref": "#/$defs/relativePath"
                },
                "comparison_review": {
                  "$ref": "#/$defs/relativePath"
                }
              }
            }
          },
          "failure_fix_retests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "failure_record",
                "fix_record",
                "retest_run",
                "review_record"
              ],
              "properties": {
                "failure_record": {
                  "$ref": "#/$defs/relativePath"
                },
                "fix_record": {
                  "$ref": "#/$defs/relativePath"
                },
                "retest_run": {
                  "$ref": "#/$defs/relativePath"
                },
                "review_record": {
                  "$ref": "#/$defs/relativePath"
                }
              }
            }
          },
          "competition_validation_records": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "runtime_pack_manifest",
                "runtime_pack_manifest_sha256",
                "result_record"
              ],
              "properties": {
                "runtime_pack_manifest": {
                  "$ref": "#/$defs/relativePath"
                },
                "runtime_pack_manifest_sha256": {
                  "$ref": "#/$defs/sha256"
                },
                "result_record": {
                  "$ref": "#/$defs/relativePath"
                }
              }
            }
          },
          "human_approval_record": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "schema_version",
              "patch_id",
              "target_status",
              "policy_version",
              "decision",
              "reviewer",
              "reviewed_at",
              "evidence_digest"
            ],
            "properties": {
              "evidence_digest": {
                "$ref": "#/$defs/sha256"
              },
              "reviewer": {
                "type": "string",
                "minLength": 1
              },
              "decision": {
                "const": "approved"
              },
              "patch_id": {
                "type": "string",
                "pattern": "^[A-Z][0-9]{3}$"
              },
              "target_status": {
                "const": "competition_evidenced"
              },
              "schema_version": {
                "const": "1.0.0"
              },
              "policy_version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "reviewed_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "failure_fix_record": {
        "type": "string"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "status": {
              "const": "competition_evidenced"
            }
          },
          "required": [
            "status"
          ]
        },
        "then": {
          "required": [
            "stable_evidence"
          ]
        }
      }
    ]
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
