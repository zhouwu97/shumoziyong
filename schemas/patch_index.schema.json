{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/patch_index.schema.json",
  "title": "Patch 索引",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["patch_id", "file", "source", "problem_type", "keywords", "runtime_profiles", "status", "applicable_when", "misuse_risks", "tested_on", "validation_records", "priority"],
    "properties": {
      "patch_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
      "file": {"type": "string", "pattern": "^prompt_patches/.+\\.md$"},
      "source": {
        "type": "object",
        "additionalProperties": false,
        "required": ["paper_id", "title", "year", "knowledge_card", "page_refs", "evidence_quotes"],
        "properties": {
          "paper_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
          "title": {"type": "string", "minLength": 1},
          "year": {"type": "integer", "minimum": 2000, "maximum": 2100},
          "knowledge_card": {"type": "string", "pattern": "^papers/.+\\.json$"},
          "page_refs": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
          "evidence_quotes": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      },
      "problem_type": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "keywords": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "runtime_profiles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}},
      "status": {"enum": ["draft", "candidate", "verified_candidate", "stable", "deprecated"]},
      "applicable_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
      "misuse_risks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
      "tested_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "validation_records": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
      "priority": {"type": "integer", "minimum": 0},
      "stable_evidence": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "negative_control_runs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["experiment_group_id", "case", "baseline_run", "treatment_run", "comparison_review"],
              "properties": {
                "experiment_group_id": {"type": "string"},
                "case": {"type": "string"},
                "baseline_run": {"type": "string"},
                "treatment_run": {"type": "string"},
                "comparison_review": {"type": "string"}
              }
            }
          },
          "failure_fix_retests": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["failure_record", "fix_record", "retest_run", "review_record"],
              "properties": {
                "failure_record": {"type": "string"},
                "fix_record": {"type": "string"},
                "retest_run": {"type": "string"},
                "review_record": {"type": "string"}
              }
            }
          },
          "competition_validation_records": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["runtime_pack_manifest", "runtime_pack_manifest_sha256", "result_record"],
              "properties": {
                "runtime_pack_manifest": {"type": "string"},
                "runtime_pack_manifest_sha256": {"type": "string"},
                "result_record": {"type": "string"}
              }
            }
          },
          "human_approval_record": {
            "type": "object",
            "required": ["evidence_digest", "approved_by", "approved_at"],
            "properties": {
              "evidence_digest": {"type": "string"},
              "approved_by": {"type": "string"},
              "approved_at": {"type": "string"}
            }
          }
        }
      },
      "failure_fix_record": {"type": "string"}
    }
  }
}
