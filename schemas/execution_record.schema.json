{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/execution_record.schema.json",
  "title": "候选执行记录",
  "description": "Executor 真实运行的原始记录。它只能证明候选执行发生过，不能作为 Gate 3 正式结果。",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "execution_spec_sha256", "executor_id", "execution_mode", "status", "started_at", "completed_at", "environment", "task_executions", "formal_result_authority"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "candidate_execution_record"},
    "run_id": {"type": "string", "minLength": 1},
    "execution_spec_sha256": {"$ref": "#/$defs/sha256"},
    "executor_id": {"type": "string", "minLength": 1},
    "execution_mode": {"const": "trusted_local"},
    "status": {"enum": ["completed", "blocked"]},
    "started_at": {"type": "string", "format": "date-time"},
    "completed_at": {"type": "string", "format": "date-time"},
    "environment": {"type": "object", "additionalProperties": false, "required": ["python", "platform", "cwd"], "properties": {"python": {"type": "string", "minLength": 1}, "platform": {"type": "string", "minLength": 1}, "cwd": {"type": "string", "minLength": 1}}},
    "task_executions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["execution_id", "task_id", "seed", "argv", "working_directory", "started_at", "completed_at", "exit_code", "stdout", "stderr", "inputs", "outputs", "acceptance_checks"], "properties": {"execution_id": {"type": "string", "minLength": 1}, "task_id": {"type": "string", "minLength": 1}, "seed": {"type": "integer", "minimum": 0}, "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "working_directory": {"type": "string", "minLength": 1}, "started_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"}, "exit_code": {"type": ["integer", "null"]}, "stdout": {"$ref": "#/$defs/fileRef"}, "stderr": {"$ref": "#/$defs/fileRef"}, "inputs": {"type": "array", "items": {"$ref": "#/$defs/fileRef"}}, "outputs": {"type": "array", "items": {"$ref": "#/$defs/fileRef"}}, "acceptance_checks": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["check_id", "status", "detail"], "properties": {"check_id": {"type": "string", "minLength": 1}, "status": {"enum": ["passed", "failed", "not_evaluated"]}, "detail": {"type": "string", "minLength": 1}}}}}}},
    "blocker_ref": {"type": ["string", "null"]},
    "formal_result_authority": {"const": "collector_required"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "fileRef": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "size_bytes"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}}}
  }
}
