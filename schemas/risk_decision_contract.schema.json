{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/risk_decision_contract.schema.json",
  "title": "风险处置合同",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "subproblem_id",
    "model_route_v3_sha256",
    "unexplained_downgrade_forbidden",
    "risks"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "risk_decision_contract_v1"},
    "run_id": {"type": "string", "minLength": 1},
    "subproblem_id": {"type": "string", "minLength": 1},
    "model_route_v3_sha256": {"$ref": "#/$defs/sha256"},
    "unexplained_downgrade_forbidden": {"const": true},
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk_id",
          "category",
          "trigger",
          "severity",
          "default_action",
          "allowed_degradations",
          "evidence_required"
        ],
        "properties": {
          "risk_id": {"type": "string", "pattern": "^RISK-[A-Z0-9_-]+$"},
          "category": {
            "enum": ["feasibility", "data_leakage", "instability", "business", "physical", "reproducibility", "claim_overreach"]
          },
          "trigger": {"type": "string", "minLength": 5},
          "severity": {"enum": ["low", "medium", "high", "fatal"]},
          "default_action": {"enum": ["advisory", "technical_report_only", "block"]},
          "allowed_degradations": {
            "type": "array",
            "uniqueItems": true,
            "items": {"enum": ["advisory", "technical_report_only", "block"]}
          },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 3}
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
