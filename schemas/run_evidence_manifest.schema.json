{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/run_evidence_manifest.schema.json",
  "title": "运行证据清单",
  "description": "一次运行用于晋级判断的全部证据及其内容哈希。路径相对于 run_evidence_manifest.json 所在运行目录。",
  "type": "object",
  "additionalProperties": false,
  "required": ["evidence_manifest_version", "run_id", "artifacts"],
  "properties": {
    "evidence_manifest_version": {"type": "string", "const": "2.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "formal_result_activation_status": {"enum": ["code_complete_candidate", "sandboxie_environment_verified"]},
    "sandboxie_environment_observed": {"type": "boolean"},
    "sandboxie_environment_verified": {"type": "boolean"},
    "formal_result_executed_in_verified_environment": {"const": false},
    "formal_result_eligible": {"type": "boolean"},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "evidence_reference.schema.json"}
    }
  },
  "dependentRequired": {
    "formal_result_activation_status": ["sandboxie_environment_observed", "sandboxie_environment_verified", "formal_result_executed_in_verified_environment", "formal_result_eligible"],
    "sandboxie_environment_observed": ["formal_result_activation_status", "sandboxie_environment_verified", "formal_result_executed_in_verified_environment", "formal_result_eligible"],
    "sandboxie_environment_verified": ["formal_result_activation_status", "sandboxie_environment_observed", "formal_result_executed_in_verified_environment", "formal_result_eligible"],
    "formal_result_executed_in_verified_environment": ["formal_result_activation_status", "sandboxie_environment_observed", "sandboxie_environment_verified", "formal_result_eligible"],
    "formal_result_eligible": ["formal_result_activation_status", "sandboxie_environment_observed", "sandboxie_environment_verified", "formal_result_executed_in_verified_environment"]
  },
  "allOf": [
    {
      "if": {"properties": {"formal_result_activation_status": {"const": "code_complete_candidate"}}, "required": ["formal_result_activation_status"]},
      "then": {"properties": {"sandboxie_environment_observed": {"const": false}, "sandboxie_environment_verified": {"const": false}, "formal_result_executed_in_verified_environment": {"const": false}, "formal_result_eligible": {"const": false}}}
    },
    {
      "if": {"properties": {"formal_result_activation_status": {"const": "sandboxie_environment_verified"}}, "required": ["formal_result_activation_status"]},
      "then": {"properties": {"sandboxie_environment_observed": {"const": true}, "sandboxie_environment_verified": {"const": true}, "formal_result_executed_in_verified_environment": {"const": false}, "formal_result_eligible": {"const": false}}}
    }
  ]
}
