{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/executor_handoff.schema.json",
  "title": "Executor 交接记录",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "execution_spec_sha256", "executor_id", "candidate_workspace", "authorized_task_ids", "prohibitions"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "executor_handoff"},
    "run_id": {"type": "string", "minLength": 1},
    "execution_spec_sha256": {"$ref": "#/$defs/sha256"},
    "executor_id": {"type": "string", "minLength": 1},
    "candidate_workspace": {"type": "string", "pattern": "^workspace(/[^/\\\\]+)*$"},
    "authorized_task_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"}},
    "prohibitions": {"type": "array", "uniqueItems": true, "contains": {"const": "modify_execution_spec"}, "items": {"enum": ["modify_execution_spec", "modify_problem_materials", "advance_gate", "declare_formal_result", "access_network", "read_outside_declared_workspace"]}}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
