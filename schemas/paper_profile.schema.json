{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_profile.schema.json",
  "title": "提交论文 Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "competition_family",
    "language",
    "approved_renderers",
    "heading",
    "body",
    "table",
    "formula",
    "engine",
    "paper",
    "margins_cm",
    "font_sizes_pt",
    "font_candidates",
    "colors",
    "paragraph",
    "table_style",
    "page_number"
  ],
  "properties": {
    "profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]+$"},
    "competition_family": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 2},
    "approved_renderers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "template_id"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]+$"},
          "template_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]+$"}
        }
      }
    },
    "heading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["color", "colored_allowed", "font_role"],
      "properties": {
        "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "colored_allowed": {"type": "boolean"},
        "font_role": {"type": "string", "minLength": 1}
      }
    },
    "body": {
      "type": "object",
      "additionalProperties": false,
      "required": ["font_role", "justify"],
      "properties": {
        "font_role": {"type": "string", "minLength": 1},
        "justify": {"type": "boolean"}
      }
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style", "fill_allowed"],
      "properties": {
        "style": {"type": "string", "minLength": 1},
        "fill_allowed": {"type": "boolean"}
      }
    },
    "formula": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_requires_math_environment"],
      "properties": {
        "block_requires_math_environment": {"type": "boolean"}
      }
    },
    "engine": {"type": "string", "minLength": 1},
    "paper": {"type": "string", "minLength": 1},
    "margins_cm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top", "bottom", "left", "right"],
      "properties": {
        "top": {"type": "number", "exclusiveMinimum": 0},
        "bottom": {"type": "number", "exclusiveMinimum": 0},
        "left": {"type": "number", "exclusiveMinimum": 0},
        "right": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "font_sizes_pt": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "number", "exclusiveMinimum": 0}
    },
    "font_candidates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serif", "sans", "math"],
      "properties": {
        "serif": {"$ref": "#/$defs/nonEmptyStrings"},
        "sans": {"$ref": "#/$defs/nonEmptyStrings"},
        "math": {"$ref": "#/$defs/nonEmptyStrings"}
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["body", "heading", "caption", "colored_heading_allowed", "table_fill_allowed"],
      "properties": {
        "body": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "heading": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "caption": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}$"},
        "colored_heading_allowed": {"type": "boolean"},
        "table_fill_allowed": {"type": "boolean"}
      }
    },
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["justify", "first_line_indent_em", "line_leading_em"],
      "properties": {
        "justify": {"type": "boolean"},
        "first_line_indent_em": {"type": "number", "minimum": 0},
        "line_leading_em": {"type": "number", "minimum": 0}
      }
    },
    "table_style": {"type": "string", "minLength": 1},
    "page_number": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
