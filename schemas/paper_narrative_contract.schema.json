{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_narrative_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "requirements", "forbidden_main_paper_terms", "hash_pattern", "failure_policy"],
  "properties": {
    "schema_version": {"const": "paper_narrative_contract_v1"},
    "contract_id": {"const": "competition_paper_narrative_v1"},
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thesis", "core_contributions", "model_choice_reason", "result_insights", "action_recommendations", "limitations"],
      "properties": {
        "thesis": {"$ref": "#/$defs/cardinality"},
        "core_contributions": {"$ref": "#/$defs/cardinality"},
        "model_choice_reason": {"$ref": "#/$defs/cardinality"},
        "result_insights": {"$ref": "#/$defs/cardinality"},
        "action_recommendations": {"$ref": "#/$defs/cardinality"},
        "limitations": {"$ref": "#/$defs/cardinality"}
      }
    },
    "forbidden_main_paper_terms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "hash_pattern": {"const": "(?i)(?<![a-f0-9])[a-f0-9]{64}(?![a-f0-9])"},
    "failure_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["submission_allowed", "technical_report_allowed", "gate4_pass_decided"],
      "properties": {
        "submission_allowed": {"const": false},
        "technical_report_allowed": {"const": true},
        "gate4_pass_decided": {"const": false}
      }
    }
  },
  "$defs": {
    "cardinality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_items", "max_items", "evidence_required"],
      "properties": {
        "min_items": {"type": "integer", "minimum": 1},
        "max_items": {"type": "integer", "minimum": 1},
        "evidence_required": {"const": true}
      }
    }
  }
}
