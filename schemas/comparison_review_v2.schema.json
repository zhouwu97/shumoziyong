{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/comparison_review_v2.schema.json",
  "title": "统一正向、边界和负控对照审核",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_version",
    "reviewer",
    "reviewed_at",
    "experiment_group_id",
    "control_type",
    "target_patch",
    "baseline_run",
    "treatment_run",
    "baseline_evidence_manifest_sha256",
    "treatment_evidence_manifest_sha256",
    "expected_behavior",
    "difference_metrics",
    "risk_items",
    "consistency_checks",
    "final_conclusion",
    "reason"
  ],
  "properties": {
    "review_version": {"const": "2.0.0"},
    "reviewer": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "experiment_group_id": {"type": "string", "minLength": 1},
    "control_type": {"enum": ["positive", "boundary", "negative"]},
    "target_patch": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
    "baseline_run": {"type": "string", "minLength": 1},
    "treatment_run": {"type": "string", "minLength": 1},
    "baseline_evidence_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "treatment_evidence_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "expected_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "treatment", "acceptable_difference"],
      "properties": {
        "baseline": {"type": "string", "minLength": 10},
        "treatment": {"type": "string", "minLength": 10},
        "acceptable_difference": {"type": "string", "minLength": 10}
      }
    },
    "difference_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "baseline", "treatment", "interpretation"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "baseline": {"type": ["number", "string", "boolean", "null"]},
          "treatment": {"type": ["number", "string", "boolean", "null"]},
          "interpretation": {"type": "string", "minLength": 10}
        }
      }
    },
    "risk_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk_id", "observed", "severity", "evidence"],
        "properties": {
          "risk_id": {"type": "string", "minLength": 1},
          "observed": {"type": "boolean"},
          "severity": {"enum": ["low", "medium", "high", "critical"]},
          "evidence": {"type": "string", "minLength": 10}
        }
      }
    },
    "consistency_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "same_problem_id",
        "same_material_digest",
        "same_model_parameters",
        "same_runtime_environment",
        "same_experiment_group",
        "same_runtime_version",
        "only_target_patch_differs",
        "responses_independently_generated"
      ],
      "properties": {
        "same_problem_id": {"type": "boolean"},
        "same_material_digest": {"type": "boolean"},
        "same_model_parameters": {"type": "boolean"},
        "same_runtime_environment": {"type": "boolean"},
        "same_experiment_group": {"type": "boolean"},
        "same_runtime_version": {"type": "boolean"},
        "only_target_patch_differs": {"type": "boolean"},
        "responses_independently_generated": {"type": "boolean"}
      }
    },
    "final_conclusion": {"enum": ["pass", "fail", "invalid", "needs_retest"]},
    "reason": {"type": "string", "minLength": 20}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
