{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/runtime_profile.schema.json",
  "title": "Runtime Profile 证据引用状态",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "version",
    "maturity",
    "base_version",
    "plugin_version",
    "validation_records",
    "known_failures",
    "last_updated"
  ],
  "properties": {
    "profile_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "maturity": {
      "enum": ["draft", "assembled", "regression_verified", "competition_evidenced", "deprecated"]
    },
    "base_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "plugin_version": {"type": ["string", "null"], "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "validation_records": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["record_id", "kind", "path", "sha256"],
        "properties": {
          "record_id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["control_review", "full_run", "competition"]},
          "control_type": {"enum": ["positive", "boundary", "negative"]},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        },
        "allOf": [
          {
            "if": {"properties": {"kind": {"const": "control_review"}}, "required": ["kind"]},
            "then": {"required": ["control_type"]},
            "else": {"not": {"required": ["control_type"]}}
          }
        ]
      }
    },
    "known_failures": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "last_updated": {"type": "string", "format": "date"},
    "deprecation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deprecated_at", "reason"],
      "properties": {
        "deprecated_at": {"type": "string", "format": "date"},
        "reason": {"type": "string", "minLength": 10}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"maturity": {"const": "deprecated"}}, "required": ["maturity"]},
      "then": {"required": ["deprecation"]},
      "else": {"not": {"required": ["deprecation"]}}
    }
  ]
}
