{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/a092_confirmatory_v2.schema.json",
  "title": "A092 确认性实验 v2 预注册协议",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "schema_version", "protocol_id", "patch_id", "patch_status", "state",
    "execution_started", "pilot_evidence_allowed", "prerequisites", "case_roles",
    "paired_runs", "attempt_isolation", "external_validation", "controls",
    "tolerances", "promotion_thresholds", "solution_failure", "experiment_invalid"
  ],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema_version": {"const": "2.0.0"},
    "protocol_id": {"const": "A092-CONFIRMATORY-V2"},
    "patch_id": {"const": "A092"},
    "patch_status": {"const": "review_ready"},
    "state": {"const": "frozen_pre_execution"},
    "execution_started": {"const": false},
    "pilot_evidence_allowed": {"const": false},
    "prerequisites": {"type": "object"},
    "case_roles": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "object"}},
    "paired_runs": {"type": "object"},
    "attempt_isolation": {"type": "object"},
    "external_validation": {"type": "object"},
    "controls": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "tolerances": {"type": "object"},
    "promotion_thresholds": {"type": "object"},
    "solution_failure": {"type": "object"},
    "experiment_invalid": {"type": "object"}
  }
}
