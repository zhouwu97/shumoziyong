{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/template_source_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source", "tree_hash_algorithm", "logical_keys", "templates"],
  "properties": {
    "schema_version": {"const": "template_source_manifest_v1"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "license_path", "template_root"],
      "properties": {
        "repository": {"const": "https://github.com/jihe520/MathModelAgent.git"},
        "commit": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
        "license_path": {"const": "docs/md/License.md"},
        "template_root": {"const": "skills/5writing/templates"}
      }
    },
    "tree_hash_algorithm": {"const": "sha256-canonical-json-v1"},
    "logical_keys": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "items": {"$ref": "#/$defs/logicalKey"}
    },
    "templates": {
      "type": "array",
      "minItems": 34,
      "maxItems": 34,
      "items": {"$ref": "#/$defs/template"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![/\\\\])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$"
    },
    "logicalKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "language", "competition_family", "aliases", "default_engine", "fallback_engine", "upstream_default_engine", "upstream_default_overridden", "templates"],
      "properties": {
        "key": {"type": "string", "pattern": "^(?:zh|en)/[a-z0-9_-]+$"},
        "language": {"enum": ["zh", "en"]},
        "competition_family": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "aliases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "default_engine": {"const": "typst"},
        "fallback_engine": {"const": "xelatex"},
        "upstream_default_engine": {"const": "xelatex"},
        "upstream_default_overridden": {"const": true},
        "templates": {
          "type": "object",
          "additionalProperties": false,
          "required": ["typst", "xelatex"],
          "properties": {
            "typst": {"type": "string", "pattern": "^mma_(?:zh|en)_[a-z0-9_]+_typst_v1$"},
            "xelatex": {"type": "string", "pattern": "^mma_(?:zh|en)_[a-z0-9_]+_xelatex_v1$"}
          }
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": {"$ref": "#/$defs/relativePath"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template_id", "logical_key", "language", "competition_family", "engine", "renderer_id", "source_dir", "entry", "file_count", "tree_sha256", "files"],
      "properties": {
        "template_id": {"type": "string", "pattern": "^mma_(?:zh|en)_[a-z0-9_]+_(?:typst|xelatex)_v1$"},
        "logical_key": {"type": "string", "pattern": "^(?:zh|en)/[a-z0-9_-]+$"},
        "language": {"enum": ["zh", "en"]},
        "competition_family": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "engine": {"enum": ["typst", "xelatex"]},
        "renderer_id": {"enum": ["typst", "xelatex"]},
        "source_dir": {"$ref": "#/$defs/relativePath"},
        "entry": {"pattern": "^main\\.(?:typ|tex)$"},
        "file_count": {"type": "integer", "minimum": 1},
        "tree_sha256": {"$ref": "#/$defs/sha256"},
        "files": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}}
      }
    }
  }
}
