{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/knowledge_card.schema.json",
  "title": "论文知识卡片",
  "type": "object",
  "required": ["paper_id", "paper_title", "source", "problem_types", "core_problem", "main_value", "problem_understanding", "problem_decomposition", "model_route", "models", "reusable_experience"],
  "properties": {
    "paper_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
    "paper_title": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "required": ["paper_id", "title", "year", "page_refs", "evidence_quotes", "extraction_date", "verification_status", "claims"],
      "properties": {
        "paper_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
        "title": {"type": "string", "minLength": 1},
        "year": {"type": "integer", "minimum": 2000, "maximum": 2100},
        "page_refs": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
        "evidence_quotes": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "extraction_date": {"type": "string", "format": "date"},
        "verification_status": {"enum": ["unverified", "verified"]},
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["claim_id", "page", "source_excerpt", "confidence", "transfer_scope", "misuse_risk", "source_behavior", "transferable_mechanism", "operational_rule", "applicable_when", "not_applicable_when", "machine_artifacts"],
            "properties": {
              "claim_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}-C[0-9]{3}$"},
              "page": {"type": "integer", "minimum": 1},
              "source_excerpt": {"type": "string", "minLength": 10},
              "confidence": {"enum": ["low", "medium", "high"]},
              "transfer_scope": {"type": "string", "minLength": 10},
              "misuse_risk": {"type": "string", "minLength": 10},
              "source_behavior": {"type": "string", "minLength": 10},
              "transferable_mechanism": {"type": "string", "minLength": 10},
              "operational_rule": {"type": "string", "minLength": 3},
              "applicable_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "not_applicable_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "machine_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"verification_status": {"const": "verified"}}, "required": ["verification_status"]},
          "then": {"properties": {"claims": {"minItems": 1}}}
        }
      ]
    },
    "problem_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "core_problem": {"type": "string", "minLength": 1},
    "main_value": {"type": "string", "minLength": 1},
    "problem_understanding": {"type": "object"},
    "problem_decomposition": {"type": "array", "minItems": 1},
    "model_route": {"type": "array", "minItems": 1},
    "models": {"type": "array", "minItems": 1},
    "reusable_experience": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
