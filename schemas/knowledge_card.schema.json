{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/knowledge_card.schema.json",
  "title": "论文知识卡片",
  "type": "object",
  "required": ["paper_id", "paper_title", "source", "problem_types", "core_problem", "main_value", "problem_understanding", "problem_decomposition", "model_route", "models", "reusable_experience"],
  "properties": {
    "paper_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
    "paper_title": {"type": "string", "minLength": 1},
    "source": {
      "type": "object",
      "required": ["paper_id", "title", "year", "page_refs", "evidence_quotes", "extraction_date"],
      "properties": {
        "paper_id": {"type": "string", "pattern": "^[A-Z][0-9]{3}$"},
        "title": {"type": "string", "minLength": 1},
        "year": {"type": "integer", "minimum": 2000, "maximum": 2100},
        "page_refs": {"type": "array", "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
        "evidence_quotes": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "extraction_date": {"type": "string", "format": "date"}
      }
    },
    "problem_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "core_problem": {"type": "string", "minLength": 1},
    "main_value": {"type": "string", "minLength": 1},
    "problem_understanding": {"type": "object"},
    "problem_decomposition": {"type": "array", "minItems": 1},
    "model_route": {"type": "array", "minItems": 1},
    "models": {"type": "array", "minItems": 1},
    "reusable_experience": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
