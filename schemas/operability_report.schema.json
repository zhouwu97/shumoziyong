{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/operability_report.schema.json",
  "title": "方案可执行性独立报告",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "operability_contract_sha256",
    "formal_result_sha256",
    "selected_route_id",
    "checks",
    "overall_status",
    "hard_violations",
    "validator"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "operability_report_v1"},
    "run_id": {"type": "string", "minLength": 1},
    "operability_contract_sha256": {"$ref": "#/$defs/sha256"},
    "formal_result_sha256": {"$ref": "#/$defs/sha256"},
    "selected_route_id": {"type": "string", "pattern": "^R-[A-Z0-9_-]+$"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "strength", "status", "observed", "evidence_refs"],
        "properties": {
          "check_id": {"type": "string", "pattern": "^OP-[A-Z0-9_-]+$"},
          "strength": {"enum": ["hard", "soft"]},
          "status": {"enum": ["passed", "failed", "not_evaluated"]},
          "observed": {"type": "string", "minLength": 2},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/evidenceRef"}
          }
        }
      }
    },
    "overall_status": {"enum": ["passed", "failed"]},
    "hard_violations": {
      "type": "array",
      "items": {"type": "string", "minLength": 2}
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_id", "independent_from_executor"],
      "properties": {
        "validator_id": {"type": "string", "minLength": 2},
        "independent_from_executor": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 3},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
