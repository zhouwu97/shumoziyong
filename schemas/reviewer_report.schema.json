{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/reviewer_report.schema.json",
  "title": "双角色审稿报告",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "reviewer_id", "review_role", "review_round", "reviewed_bundle_sha256", "input_artifacts", "forbidden_inputs_confirmed", "write_access", "independence_mode", "reviewer_model", "prompt_profile", "findings", "decision"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "reviewer_report"},
    "run_id": {"type": "string", "minLength": 1},
    "reviewer_id": {"type": "string", "minLength": 1},
    "review_role": {"enum": ["model", "paper"]},
    "review_round": {"enum": [1, 2]},
    "reviewed_bundle_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "input_artifacts": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["path", "sha256", "category"], "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}, "category": {"enum": ["problem", "model_contract", "formal_result", "validity_report", "manuscript", "claim_map", "figure", "review_report", "execution_chat", "other"]}}}},
    "forbidden_inputs_confirmed": {"const": true},
    "write_access": {"const": false},
    "independence_mode": {"enum": ["independent", "role_separated_review"]},
    "findings": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["finding_id", "severity", "resolved", "message"], "properties": {"finding_id": {"type": "string", "minLength": 1}, "severity": {"enum": ["fatal", "major", "minor", "editorial"]}, "resolved": {"type": "boolean"}, "message": {"type": "string", "minLength": 10}, "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}}}},
    "decision": {"enum": ["pass", "revise", "reject"]},
    "reviewer_model": {"type": "string", "minLength": 1},
    "prompt_profile": {"type": "string", "minLength": 1},
    "prior_round_report_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "remediation_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
