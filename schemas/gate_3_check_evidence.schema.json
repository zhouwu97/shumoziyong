{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/gate_3_check_evidence.schema.json",
  "title": "Gate 3 可执行数学检查证据",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "execution_attestation_path", "execution_attestation_sha256", "checks"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "execution_attestation_path": {"type": "string", "minLength": 1},
    "execution_attestation_sha256": {"$ref": "#/$defs/sha256"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id", "check_type", "validator_path", "validator_sha256",
        "validator_contract_path", "validator_contract_sha256",
        "input_manifest_path", "input_manifest_sha256", "report_path",
        "report_sha256", "exit_code", "observations", "passed"
      ],
      "properties": {
        "check_id": {"type": "string", "minLength": 1},
        "check_type": {
          "enum": [
            "independent_recomputation", "constraint_residual",
            "decision_output_consistency", "variable_domain", "solver_status",
            "random_seed_replay", "sample_manifest_consistency"
          ]
        },
        "validator_path": {"type": "string", "pattern": "^validators/.+"},
        "validator_sha256": {"$ref": "#/$defs/sha256"},
        "validator_contract_path": {"type": "string", "pattern": "^validators/.+\\.json$"},
        "validator_contract_sha256": {"$ref": "#/$defs/sha256"},
        "input_manifest_path": {"type": "string", "minLength": 1},
        "input_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "report_path": {"type": "string", "minLength": 1},
        "report_sha256": {"$ref": "#/$defs/sha256"},
        "exit_code": {"type": "integer"},
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "value", "comparison", "threshold", "passed"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "value": {"type": "number"},
              "comparison": {"enum": ["le", "lt", "ge", "gt", "eq", "ne"]},
              "threshold": {"type": "number"},
              "passed": {"type": "boolean"}
            }
          }
        },
        "passed": {"type": "boolean"}
      }
    }
  }
}
