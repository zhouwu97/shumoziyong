{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/competition_full_replay_campaign.schema.json",
  "title": "Competition Production 多题 full_replay Campaign 合同",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "contract_id", "capability_id", "activation_context",
    "lifecycle_path", "current_lifecycle", "target_lifecycle",
    "new_problem_default_enabled", "earliest_run_created_at", "required_problems",
    "required_runtime_plugin", "required_run_artifacts", "pass_policy"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "contract_id": {"const": "competition_full_replay_campaign_v1"},
    "capability_id": {"const": "competition_production_v1"},
    "activation_context": {"const": "full_replay"},
    "lifecycle_path": {
      "const": [
        "draft", "review_ready", "full_replay_passed", "qualification_candidate",
        "blind_review_passed", "default_candidate"
      ]
    },
    "current_lifecycle": {"const": "review_ready"},
    "target_lifecycle": {"const": "full_replay_passed"},
    "new_problem_default_enabled": {"const": false},
    "earliest_run_created_at": {"type": "string", "format": "date-time"},
    "required_problems": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["problem_id", "material_key", "allowed_profiles"],
        "properties": {
          "problem_id": {"enum": ["2016-C", "2023-B", "2024-B", "2024-C", "2024-D"]},
          "material_key": {"enum": ["2016_C", "2023_B", "2024_B", "2024_C", "2024_D"]},
          "allowed_profiles": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["general", "engineering_optimization", "evaluation", "prediction"]}
          }
        }
      }
    },
    "required_runtime_plugin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"const": "prompt_plugins/plugin_competition_production_v1.md"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "required_run_artifacts": {
      "const": [
        "competition_production_adapter_report.json", "model_route_v3.json",
        "full_replay_run_record.json", "paper_candidate_manifest.json"
      ]
    },
    "pass_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_all_problems", "require_all_subproblems", "require_gate3_allow_paper",
        "require_score_v3_submission", "require_no_fatal_codes", "require_gate4_candidate",
        "require_no_time_leakage", "require_no_answer_leakage",
        "require_historical_assets_unchanged"
      ],
      "properties": {
        "require_all_problems": {"const": true},
        "require_all_subproblems": {"const": true},
        "require_gate3_allow_paper": {"const": true},
        "require_score_v3_submission": {"const": true},
        "require_no_fatal_codes": {"const": true},
        "require_gate4_candidate": {"const": true},
        "require_no_time_leakage": {"const": true},
        "require_no_answer_leakage": {"const": true},
        "require_historical_assets_unchanged": {"const": true}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
