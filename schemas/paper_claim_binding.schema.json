{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/paper_claim_binding.schema.json",
  "title": "论文 Claim 数值与显示绑定",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "problem_id", "bindings"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "paper_claim_bindings"},
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/binding"}
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["binding_id", "claim_id", "ref_type", "source", "display", "usage"],
      "properties": {
        "binding_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9._-]{4,100}$"},
        "claim_id": {"type": "string", "minLength": 1},
        "ref_type": {"enum": ["metric", "parameter", "comparison", "formula", "boundary"]},
        "source": {
          "oneOf": [
            {"$ref": "#/$defs/directSource"},
            {"$ref": "#/$defs/derivedSource"}
          ]
        },
        "display": {"$ref": "#/$defs/display"},
        "usage": {"$ref": "#/$defs/usage"}
      }
    },
    "directSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "json_pointer"],
      "properties": {
        "kind": {"const": "direct"},
        "path": {"type": "string", "minLength": 1},
        "json_pointer": {"type": "string", "pattern": "^/"},
        "unit_pointer": {"type": "string", "pattern": "^/"}
      }
    },
    "derivedSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operation", "input_binding_ids"],
      "properties": {
        "kind": {"const": "derived"},
        "operation": {"enum": ["subtract", "ratio"]},
        "input_binding_ids": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decimal_places", "scale", "prefix", "suffix", "unit"],
      "properties": {
        "decimal_places": {"type": ["integer", "null"], "minimum": 0, "maximum": 12},
        "scale": {"type": "number"},
        "prefix": {"type": "string"},
        "suffix": {"type": "string"},
        "unit": {"type": "string"},
        "literal": {"type": "string", "minLength": 1},
        "strip_terminal_punctuation": {"type": "boolean"}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement", "allowed_sections"],
      "properties": {
        "requirement": {
          "enum": ["required_once", "required_at_least_once", "optional", "repeatable"]
        },
        "allowed_sections": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden_sections": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
