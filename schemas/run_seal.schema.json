{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "不可变运行封存记录",
  "type": "object",
  "additionalProperties": false,
  "required": ["seal_version", "run_id", "sealed_at", "run_manifest_sha256", "transitions_sha256", "evidence_manifest_sha256"],
  "properties": {
    "seal_version": {"const": "1.0.0"},
    "run_id": {"type": "string", "minLength": 1},
    "sealed_at": {"type": "string", "format": "date-time"},
    "run_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "transitions_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "evidence_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "formal_result_policy": {"enum": ["required_v1", "legacy_read_only_v1"]},
    "execution_contract_version": {"const": "1.0.0"},
    "formal_result_contract_version": {"const": "1.0.0"},
    "canonicalization_version": {"const": "1.0.0"},
    "gate_artifact_contract_version": {"const": "1.0.0"},
    "formal_result_id": {"type": "string", "minLength": 1},
    "formal_result_envelope_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "formal_result_envelope_semantic_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "formal_result_activation_status": {"enum": ["code_complete_candidate", "sandboxie_environment_verified", "run_execution_verified"]},
    "sandboxie_environment_observed": {"type": "boolean"},
    "sandboxie_environment_verified": {"type": "boolean"},
    "formal_result_executed_in_verified_environment": {"type": "boolean"},
    "formal_result_eligible": {"type": "boolean"},
    "sandboxie_environment_report_id": {"type": "string", "pattern": "^sandboxie-env-[A-Za-z0-9._-]{8,96}$"},
    "sandboxie_environment_report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_report_semantic_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_attestation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_attestation_semantic_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_original_report_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_fingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_environment_machine_key_id": {"type": "string", "pattern": "^sandboxie-host-[a-f0-9]{16}$"},
    "sandboxie_configuration_backup_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "trusted_environment_registry_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "trusted_environment_key_entry_semantic_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_run_execution_attestation_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_run_execution_attestation_semantic_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "sandboxie_execution_id": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {
        "properties": {"formal_result_policy": {"const": "required_v1"}},
        "required": ["formal_result_policy"]
      },
      "then": {
        "required": [
          "execution_contract_version",
          "formal_result_contract_version",
          "canonicalization_version",
          "gate_artifact_contract_version",
          "formal_result_id",
          "formal_result_envelope_sha256",
          "formal_result_envelope_semantic_sha256",
          "formal_result_activation_status",
          "sandboxie_environment_observed",
          "sandboxie_environment_verified",
          "formal_result_executed_in_verified_environment",
          "formal_result_eligible"
        ]
      }
    },
    {
      "if": {"properties": {"formal_result_activation_status": {"const": "code_complete_candidate"}}, "required": ["formal_result_activation_status"]},
      "then": {"properties": {"sandboxie_environment_observed": {"const": false}, "sandboxie_environment_verified": {"const": false}, "formal_result_executed_in_verified_environment": {"const": false}, "formal_result_eligible": {"const": false}}}
    },
    {
      "if": {"properties": {"formal_result_activation_status": {"const": "sandboxie_environment_verified"}}, "required": ["formal_result_activation_status"]},
      "then": {
        "required": [
          "sandboxie_environment_report_id",
          "sandboxie_environment_report_sha256",
          "sandboxie_environment_report_semantic_sha256",
          "sandboxie_environment_attestation_sha256",
          "sandboxie_environment_attestation_semantic_sha256",
          "sandboxie_environment_original_report_sha256",
          "sandboxie_environment_fingerprint",
          "sandboxie_environment_machine_key_id",
          "sandboxie_configuration_backup_sha256",
          "trusted_environment_registry_sha256",
          "trusted_environment_key_entry_semantic_sha256"
        ],
        "properties": {"sandboxie_environment_observed": {"const": true}, "sandboxie_environment_verified": {"const": true}, "formal_result_executed_in_verified_environment": {"const": false}, "formal_result_eligible": {"const": false}}
      }
    },
    {
      "if": {"properties": {"formal_result_activation_status": {"const": "run_execution_verified"}}, "required": ["formal_result_activation_status"]},
      "then": {
        "required": ["sandboxie_run_execution_attestation_sha256", "sandboxie_run_execution_attestation_semantic_sha256", "sandboxie_execution_id"],
        "properties": {"sandboxie_environment_observed": {"const": true}, "sandboxie_environment_verified": {"const": true}, "formal_result_executed_in_verified_environment": {"const": true}, "formal_result_eligible": {"const": true}}
      }
    }
  ]
}
