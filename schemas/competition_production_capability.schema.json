{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/competition_production_capability.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "capability_id", "lifecycle", "profiles", "activation_contexts", "new_problem_default_enabled", "contract_version", "gate_route"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "capability_id": {"const": "competition_production_v1"},
    "lifecycle": {
      "enum": [
        "review_ready", "integration_fixture_campaign_passed", "full_replay_passed", "qualification_candidate",
        "blind_review_passed", "human_assisted_review_passed", "default_candidate"
      ]
    },
    "profiles": {"const": ["general", "engineering_optimization", "evaluation", "prediction"]},
    "activation_contexts": {
      "oneOf": [
        {"const": ["full_replay"]},
        {"const": ["full_replay", "new_problem"]}
      ]
    },
    "new_problem_default_enabled": {"type": "boolean"},
    "contract_version": {"const": "1.0.0"},
    "promotion_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "enum": [
            "capability_evidence/competition_production/integration_fixture/campaign_report_v1.json",
            "capability_evidence/competition_production/full_replay/full_replay_acceptance_report_v1.json"
          ]
        },
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "qualification_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "enum": [
            "capability_evidence/competition_production/qualification/qualification_report_v1.json",
            "capability_evidence/competition_production/qualification/qualification_report_v2.json",
            "capability_evidence/competition_production/qualification/qualification_report_v3.json"
          ]
        },
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "simulation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"const": "capability_evidence/competition_production/simulation/simulation_report_v1.json"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "gate_route": {
      "const": [
        "gate_0",
        "production_adapter",
        "gate_1_model_route_v3",
        "gate_2_three_route_execution",
        "gate_3_formal_evidence",
        "score_v3"
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"lifecycle": {"const": "review_ready"}}},
      "then": {
        "not": {
          "anyOf": [
            {"required": ["promotion_evidence"]},
            {"required": ["qualification_evidence"]}
          ]
        }
      },
      "else": {"required": ["promotion_evidence"]}
    },
    {
      "if": {
        "properties": {
          "lifecycle": {
            "enum": [
              "qualification_candidate", "blind_review_passed",
              "human_assisted_review_passed", "default_candidate"
            ]
          }
        }
      },
      "then": {"required": ["qualification_evidence"]},
      "else": {"not": {"required": ["qualification_evidence"]}}
    },
    {
      "if": {"properties": {"new_problem_default_enabled": {"const": true}}},
      "then": {"required": ["promotion_evidence"]},
      "else": {}
    },
    {
      "if": {"properties": {"lifecycle": {"const": "default_candidate"}}},
      "then": {
        "required": ["qualification_evidence", "simulation_evidence"],
        "properties": {
          "qualification_evidence": {
            "properties": {
              "path": {"const": "capability_evidence/competition_production/qualification/qualification_report_v3.json"}
            }
          }
        }
      },
      "else": {"not": {"required": ["simulation_evidence"]}}
    },
    {
      "if": {"properties": {"new_problem_default_enabled": {"const": true}}},
      "then": {
        "properties": {
          "lifecycle": {"const": "default_candidate"},
          "activation_contexts": {"const": ["full_replay", "new_problem"]}
        }
      }
    },
    {
      "if": {"properties": {"new_problem_default_enabled": {"const": false}}},
      "then": {
        "properties": {
          "activation_contexts": {"const": ["full_replay"]}
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle": {
            "enum": [
              "review_ready", "integration_fixture_campaign_passed", "full_replay_passed", "qualification_candidate",
              "blind_review_passed", "human_assisted_review_passed"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "new_problem_default_enabled": {"const": false},
          "activation_contexts": {"const": ["full_replay"]}
        }
      }
    }
  ]
}
