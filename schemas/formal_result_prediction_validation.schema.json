{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/formal_result_prediction_validation.schema.json",
  "title": "Prediction Formal Result Validation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "problem_id", "profile", "runtime_version", "runtime_pack_sha256", "formal_result_policy", "execution_contract_version", "formal_result_contract_version", "canonicalization_version", "gate_artifact_contract_version", "formal_result_id", "status", "bindings", "payload"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "prediction_validation"},
    "run_id": {"$ref": "#/$defs/id"}, "problem_id": {"$ref": "#/$defs/id"}, "profile": {"const": "prediction"},
    "runtime_version": {"$ref": "#/$defs/id"}, "runtime_pack_sha256": {"$ref": "#/$defs/sha"},
    "formal_result_policy": {"const": "required_v1"}, "execution_contract_version": {"const": "1.0.0"},
    "formal_result_contract_version": {"const": "1.0.0"}, "canonicalization_version": {"const": "1.0.0"},
    "gate_artifact_contract_version": {"const": "1.0.0"}, "formal_result_id": {"$ref": "#/$defs/id"},
    "status": {"enum": ["execution_pending", "passed"]},
    "bindings": {"type": "object", "required": ["prediction_result.json"], "additionalProperties": false, "properties": {"prediction_result.json": {"$ref": "#/$defs/sha"}}},
    "payload": {"type": "object"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "execution_pending"}}, "required": ["status"]}, "then": {"properties": {"payload": {"const": {"execution_pending": true}}}}},
    {"if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/validationPayload"}}}}
  ],
  "$defs": {
    "id": {"type": "string", "minLength": 1},
    "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "validationPayload": {"type": "object", "additionalProperties": false, "required": ["patient_split_check", "fit_scope_checks", "tasks"], "properties": {"patient_split_check": {"type": "object", "additionalProperties": false, "required": ["status", "overlap_group_count"], "properties": {"status": {"const": "passed"}, "overlap_group_count": {"const": 0}}}, "fit_scope_checks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["stage", "status"], "properties": {"stage": {"$ref": "#/$defs/id"}, "status": {"const": "passed"}}}}, "tasks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["task_id", "status", "metrics"], "properties": {"task_id": {"$ref": "#/$defs/id"}, "status": {"const": "passed"}, "metrics": {"type": "object", "minProperties": 3, "additionalProperties": {"type": "number"}}}}}}}
  }
}
