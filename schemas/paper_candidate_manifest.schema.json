{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "不可变论文候选稿",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate_id", "run_id", "parent_candidate_id", "created_at", "reason", "source_files"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "candidate_id": {"type": "string", "pattern": "^PC-[0-9]{4}$"},
    "run_id": {"type": "string", "minLength": 1},
    "parent_candidate_id": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "reason": {"type": "string", "minLength": 1},
    "trigger_review_id": {"type": ["string", "null"], "pattern": "^G5R-[A-Za-z0-9_-]{8,120}$"},
    "source_files": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_path", "path", "sha256"], "properties": {"source_path": {"type": "string", "minLength": 1}, "path": {"type": "string", "pattern": "^[A-Za-z0-9_./-]+$"}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}}},
    "legacy_gate_4_manifest_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
