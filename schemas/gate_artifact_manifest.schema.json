{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/gate_artifact_manifest.schema.json",
  "title": "单 Gate 业务产物哈希清单",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "gate",
    "completed_at",
    "run_id",
    "problem_id",
    "profile",
    "runtime_version",
    "runtime_pack_sha256",
    "artifacts"
  ],
  "properties": {
    "manifest_version": {"const": "1.0.0"},
    "gate": {"type": "integer", "minimum": 0, "maximum": 5},
    "completed_at": {"type": "string", "format": "date-time"},
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "minLength": 1},
    "runtime_version": {"type": "string", "minLength": 1},
    "runtime_pack_sha256": {"$ref": "#/$defs/sha256"},
    "formal_result_policy": {"enum": ["required_v1", "legacy_read_only_v1"]},
    "execution_contract_version": {"const": "1.0.0"},
    "formal_result_contract_version": {"const": "1.0.0"},
    "canonicalization_version": {"const": "1.0.0"},
    "gate_artifact_contract_version": {"const": "1.0.0"},
    "formal_result": {
      "type": "object", "additionalProperties": false,
      "required": ["formal_result_id", "envelope_path", "envelope_file_sha256", "envelope_semantic_sha256", "formal_result_activation_status", "formal_result_eligible"],
      "properties": {
        "formal_result_id": {"type": "string", "minLength": 1},
        "envelope_path": {"type": "string", "pattern": "^formal_results/[A-Za-z0-9._-]+/formal_result_envelope\\.json$"},
        "envelope_file_sha256": {"$ref": "#/$defs/sha256"},
        "envelope_semantic_sha256": {"$ref": "#/$defs/sha256"},
        "formal_result_activation_status": {"const": "code_complete_candidate"},
        "formal_result_eligible": {"const": false}
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "schema", "schema_version", "sha256", "size_bytes"],
        "properties": {
          "path": {"type": "string", "pattern": "^[A-Za-z0-9_./-]+\\.json$"},
          "role": {
            "enum": [
              "diagnosis",
              "model_route",
              "code_plan",
              "result_report",
              "result_manifest",
              "paper_claim_map",
              "gate_5_review"
            ]
          },
          "schema": {"type": "string", "pattern": "^schemas/[A-Za-z0-9_.-]+\\.json$"},
          "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "sha256": {"$ref": "#/$defs/sha256"},
          "size_bytes": {"type": "integer", "minimum": 1}
        }
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
