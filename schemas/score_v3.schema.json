{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/score_v3.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "subproblem_id", "scorer_id", "policy", "source_evidence", "dimensions", "raw_total", "fatal_cap_applied", "final_score", "fatal_codes", "gate3_decision", "submission_status", "submission_allowed", "technical_report_allowed"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "score_v3"},
    "run_id": {"type": "string", "minLength": 1},
    "subproblem_id": {"type": "string", "minLength": 1},
    "scorer_id": {"type": "string", "minLength": 1},
    "policy": {"$ref": "#/$defs/fileRef"},
    "source_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_route", "route_execution", "route_comparison", "operability_contract", "operability_report", "risk_contract", "risk_report", "gate3_decision"],
      "properties": {
        "model_route": {"$ref": "#/$defs/fileRef"},
        "route_execution": {"$ref": "#/$defs/fileRef"},
        "route_comparison": {"$ref": "#/$defs/fileRef"},
        "operability_contract": {"$ref": "#/$defs/fileRef"},
        "operability_report": {"$ref": "#/$defs/fileRef"},
        "risk_contract": {"$ref": "#/$defs/fileRef"},
        "risk_report": {"$ref": "#/$defs/fileRef"},
        "gate3_decision": {"$ref": "#/$defs/fileRef"}
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism_hypothesis", "business_constraints", "route_competition", "execution_completeness", "comparison_quality", "formal_evidence", "operability", "risk_robustness", "submission_readiness"],
      "properties": {
        "mechanism_hypothesis": {"$ref": "#/$defs/dimension"},
        "business_constraints": {"$ref": "#/$defs/dimension"},
        "route_competition": {"$ref": "#/$defs/dimension"},
        "execution_completeness": {"$ref": "#/$defs/dimension"},
        "comparison_quality": {"$ref": "#/$defs/dimension"},
        "formal_evidence": {"$ref": "#/$defs/dimension"},
        "operability": {"$ref": "#/$defs/dimension"},
        "risk_robustness": {"$ref": "#/$defs/dimension"},
        "submission_readiness": {"$ref": "#/$defs/dimension"}
      }
    },
    "raw_total": {"type": "number", "minimum": 0, "maximum": 100},
    "fatal_cap_applied": {"type": "boolean"},
    "final_score": {"type": "number", "minimum": 0, "maximum": 100},
    "fatal_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^V3F_[A-Z0-9_]+$"}},
    "gate3_decision": {"enum": ["allow_paper", "technical_report_only", "block"]},
    "submission_status": {"enum": ["eligible", "technical_report_only", "blocked"]},
    "submission_allowed": {"type": "boolean"},
    "technical_report_allowed": {"const": true}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 3}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["awarded_score", "evidence_ceiling", "effective_score", "weight", "weighted_score", "rationale", "evidence_refs"],
      "properties": {
        "awarded_score": {"type": "number", "minimum": 0, "maximum": 100},
        "evidence_ceiling": {"type": "number", "minimum": 0, "maximum": 100},
        "effective_score": {"type": "number", "minimum": 0, "maximum": 100},
        "weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "weighted_score": {"type": "number", "minimum": 0, "maximum": 100},
        "rationale": {"type": "string", "minLength": 10},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/fileRef"}}
      }
    }
  }
}
