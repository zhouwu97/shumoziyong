{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/failure_card.schema.json",
  "title": "失败复盘卡",
  "type": "object",
  "additionalProperties": false,
  "required": ["failure_id", "date", "test_id", "profile", "labels", "symptom", "root_cause", "repair", "regression_plan"],
  "properties": {
    "failure_id": {"type": "string", "minLength": 1},
    "date": {"type": "string", "format": "date"},
    "test_id": {"type": "string", "minLength": 1},
    "profile": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "labels": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"pattern": "^P(?:[1-9]|10)$"}},
    "symptom": {"type": "string", "minLength": 1},
    "root_cause": {"type": "string", "minLength": 1},
    "repair": {"type": "string", "minLength": 1},
    "regression_plan": {"type": "string", "minLength": 1}
  }
}
