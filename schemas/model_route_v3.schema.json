{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/model_route_v3.schema.json",
  "title": "Gate 1 三路线竞争合同 v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "run_id",
    "problem_id",
    "profile",
    "runtime_version",
    "runtime_pack_sha256",
    "lifecycle",
    "subproblems",
    "human_decisions_required"
  ],
  "properties": {
    "schema_version": {"const": "3.0.0"},
    "artifact_type": {"const": "model_route_v3"},
    "run_id": {"type": "string", "minLength": 1},
    "problem_id": {"type": "string", "minLength": 1},
    "profile": {"enum": ["general", "engineering_optimization", "evaluation", "prediction"]},
    "runtime_version": {"type": "string", "minLength": 1},
    "runtime_pack_sha256": {"$ref": "#/$defs/sha256"},
    "lifecycle": {"const": "review_ready"},
    "subproblems": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/subproblem"}
    },
    "human_decisions_required": {"$ref": "#/$defs/nonEmptyStrings"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "namedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "definition"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "definition": {"type": "string", "minLength": 1},
        "unit": {"type": ["string", "null"]},
        "source": {"type": ["string", "null"]}
      }
    },
    "mechanismHypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "rationale", "falsification_checks"],
      "properties": {
        "statement": {"type": "string", "minLength": 10},
        "rationale": {"type": "string", "minLength": 10},
        "falsification_checks": {"$ref": "#/$defs/nonEmptyStrings"}
      }
    },
    "businessConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["constraint_id", "statement", "strength", "source_ref", "verification_method"],
      "properties": {
        "constraint_id": {"type": "string", "pattern": "^BC-[A-Z0-9_-]+$"},
        "statement": {"type": "string", "minLength": 5},
        "strength": {"enum": ["hard", "soft"]},
        "source_ref": {"type": "string", "minLength": 3},
        "verification_method": {"type": "string", "minLength": 5}
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "role",
        "name",
        "structural_family",
        "rationale",
        "model",
        "assumptions",
        "decision_variables",
        "objectives",
        "constraint_ids",
        "data_requirements",
        "algorithm",
        "expected_outputs",
        "validation_requirements",
        "failure_conditions"
      ],
      "properties": {
        "route_id": {"type": "string", "pattern": "^R-[A-Z0-9_-]+$"},
        "role": {"enum": ["baseline", "primary", "structural_alternative"]},
        "name": {"type": "string", "minLength": 2},
        "structural_family": {"type": "string", "minLength": 3},
        "rationale": {"type": "string", "minLength": 10},
        "model": {"type": "string", "minLength": 2},
        "assumptions": {"$ref": "#/$defs/nonEmptyStrings"},
        "decision_variables": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/namedItem"}
        },
        "objectives": {"$ref": "#/$defs/nonEmptyStrings"},
        "constraint_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^BC-[A-Z0-9_-]+$"}
        },
        "data_requirements": {"$ref": "#/$defs/nonEmptyStrings"},
        "algorithm": {"type": "string", "minLength": 3},
        "expected_outputs": {"$ref": "#/$defs/nonEmptyStrings"},
        "validation_requirements": {"$ref": "#/$defs/nonEmptyStrings"},
        "failure_conditions": {"$ref": "#/$defs/nonEmptyStrings"}
      }
    },
    "structuralDifference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_route_id", "alternative_route_id", "differs_in", "explanation"],
      "properties": {
        "primary_route_id": {"type": "string", "pattern": "^R-[A-Z0-9_-]+$"},
        "alternative_route_id": {"type": "string", "pattern": "^R-[A-Z0-9_-]+$"},
        "differs_in": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "mechanism",
              "objective",
              "decision_representation",
              "algorithm_family",
              "constraint_formulation"
            ]
          }
        },
        "explanation": {"type": "string", "minLength": 15}
      }
    },
    "subproblem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subproblem_id",
        "task_type",
        "inputs",
        "outputs",
        "mechanism_hypothesis",
        "business_constraints",
        "routes",
        "structural_difference",
        "comparison_metrics"
      ],
      "properties": {
        "subproblem_id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"},
        "task_type": {"type": "string", "minLength": 2},
        "inputs": {"type": "array", "items": {"$ref": "#/$defs/namedItem"}},
        "outputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/namedItem"}},
        "mechanism_hypothesis": {"$ref": "#/$defs/mechanismHypothesis"},
        "business_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/businessConstraint"}
        },
        "routes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/route"},
          "allOf": [
            {"contains": {"properties": {"role": {"const": "baseline"}}, "required": ["role"]}, "minContains": 1, "maxContains": 1},
            {"contains": {"properties": {"role": {"const": "primary"}}, "required": ["role"]}, "minContains": 1, "maxContains": 1},
            {"contains": {"properties": {"role": {"const": "structural_alternative"}}, "required": ["role"]}, "minContains": 1, "maxContains": 1}
          ]
        },
        "structural_difference": {"$ref": "#/$defs/structuralDifference"},
        "comparison_metrics": {"$ref": "#/$defs/nonEmptyStrings"}
      }
    }
  }
}
