{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/formal_result_prediction_negative_tests.schema.json",
  "title": "Prediction Formal Result Negative Tests",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "run_id", "problem_id", "profile", "runtime_version", "runtime_pack_sha256", "formal_result_policy", "execution_contract_version", "formal_result_contract_version", "canonicalization_version", "gate_artifact_contract_version", "formal_result_id", "status", "bindings", "payload"],
  "properties": {
    "schema_version": {"const": "1.0.0"}, "artifact_type": {"const": "negative_tests"},
    "run_id": {"$ref": "#/$defs/id"}, "problem_id": {"$ref": "#/$defs/id"}, "profile": {"const": "prediction"},
    "runtime_version": {"$ref": "#/$defs/id"}, "runtime_pack_sha256": {"$ref": "#/$defs/sha"},
    "formal_result_policy": {"const": "required_v1"}, "execution_contract_version": {"const": "1.0.0"},
    "formal_result_contract_version": {"const": "1.0.0"}, "canonicalization_version": {"const": "1.0.0"},
    "gate_artifact_contract_version": {"const": "1.0.0"}, "formal_result_id": {"$ref": "#/$defs/id"},
    "status": {"enum": ["execution_pending", "passed"]},
    "bindings": {"type": "object", "required": ["execution_spec.json"], "additionalProperties": false, "properties": {"execution_spec.json": {"$ref": "#/$defs/sha"}}},
    "payload": {"type": "object"}
  },
  "allOf": [
    {"if": {"properties": {"status": {"const": "execution_pending"}}, "required": ["status"]}, "then": {"properties": {"payload": {"const": {"execution_pending": true}}}}},
    {"if": {"properties": {"status": {"const": "passed"}}, "required": ["status"]}, "then": {"properties": {"payload": {"$ref": "#/$defs/resultPayload"}}}}
  ],
  "$defs": {
    "id": {"type": "string", "minLength": 1}, "sha": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "resultPayload": {"type": "object", "additionalProperties": false, "required": ["results"], "properties": {"results": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["test_id", "status"], "properties": {"test_id": {"type": "string", "minLength": 1}, "status": {"const": "passed"}}}}}}
  }
}
