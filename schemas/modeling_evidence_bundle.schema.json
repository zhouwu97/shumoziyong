{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/modeling_evidence_bundle.schema.json",
  "title": "建模证据包 v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "problem_id", "bundle_status", "frozen_at", "bundle_sha256", "artifacts"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "modeling_evidence_bundle_v1"},
    "problem_id": {"type": "string", "minLength": 1},
    "bundle_status": {"const": "frozen_for_solver"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "bundle_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifacts": {
      "type": "array", "minItems": 12,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["role", "path", "sha256"],
        "properties": {
          "role": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
