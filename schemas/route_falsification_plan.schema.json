{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shumo.local/schemas/route_falsification_plan.schema.json",
  "title": "路线证伪计划 v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "artifact_type", "problem_id", "created_before_solver", "routes"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "artifact_type": {"const": "route_falsification_plan_v1"},
    "problem_id": {"type": "string", "minLength": 1},
    "created_before_solver": {"const": true},
    "routes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/route"}}
  },
  "$defs": {
    "strings": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "test": {
      "type": "object", "additionalProperties": false,
      "required": ["test_id", "category", "description", "evidence_source", "failure_effect", "triggerability"],
      "properties": {
        "test_id": {"type": "string", "pattern": "^FALS-[A-Z0-9-]+$"},
        "category": {"enum": ["analytic", "numerical", "mechanism", "data", "identifiability"]},
        "description": {"type": "string", "minLength": 10},
        "evidence_source": {"type": "string", "minLength": 1},
        "failure_effect": {"enum": ["route_rejected", "model_invalid", "claim_weakened", "fallback_required"]},
        "triggerability": {"enum": ["demonstrated_by_fixture", "threshold_defined"]}
      }
    },
    "route": {
      "type": "object", "additionalProperties": false,
      "required": ["route_id", "subproblem_id", "role", "mechanism_claims", "identifiability_risks", "falsification_tests"],
      "properties": {
        "route_id": {"type": "string", "pattern": "^R-[A-Z0-9-]+$"},
        "subproblem_id": {"enum": ["Q3", "Q4"]},
        "role": {"enum": ["baseline", "primary", "structural_alternative"]},
        "mechanism_claims": {"$ref": "#/$defs/strings"},
        "identifiability_risks": {"$ref": "#/$defs/strings"},
        "falsification_tests": {"type": "array", "items": {"$ref": "#/$defs/test"}},
        "fallback_route_id": {"type": "string", "pattern": "^R-[A-Z0-9-]+$"}
      }
    }
  }
}
