    {
      "rule_id": "R002_baseline_and_validation",
      "status": "global_active",
      "rule": "核心结论必须有统一评价口径、可复算基线和与声明强度相匹配的验证证据。",
      "evidence_sources": [
        "2023_A092",
        "2023_A127",
        "2023_B477"
      ],
      "use": "scored_and_blocking_when_core_claim_fails"
