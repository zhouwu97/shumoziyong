    {
      "rule_id": "R003_figures_as_evidence",
      "status": "global_active",
      "rule": "图表必须服务推理链并与正文、结果和附件一致，图多本身不构成质量。",
      "evidence_sources": [
        "2023_A092",
        "2023_A127",
        "2023_B311",
        "2023_B477"
      ],
      "use": "scored"
    },
    {
      "rule_id": "R004_honest_scope",
      "status": "global_active",
      "rule": "局部、受限、启发式或样本内结果必须明确边界，不得夸大为全局最优或普遍规律。",
      "evidence_sources": [
        "2023_A092",
        "2023_B311",
        "2023_B477"
      ],
      "use": "scored_and_blocking_when_misleading"
    },
    {
      "rule_id": "R005_problem_driven_innovation",
      "status": "global_active",
      "rule": "创新必须说明相对基线的实际新增机制、题意依据、证据增益和适用边界；算法名堆砌不算创新。",
      "evidence_sources": [
        "2023_A092",
        "2023_A127",
        "2023_B477"
      ],
