    "global_activation_requirements": [
      "关键 claim 已核验",
      "至少有跨论文重复证据，并有 production_replay 或陌生题完整生产证据",
      "已记录适用范围、误用风险和不可迁移内容",
      "已完成同义规则去重以及反例/冲突检查",
      "已完成与现有规则的冲突检查",
      "评审工作流已记录版本和变更理由"
    ],
    "prohibited": [
      "用同题优秀论文答案反向对答案",
      "把奖项标签或算法名称当作质量证据",
      "把单篇未核验经验自动升级为全局硬规则",
      "静默覆盖存在冲突的旧规则",
      "用 diagnostic、Prompt 回归、文件生成或旧 Gate 通过替代生产验证",
      "为语义相同规则重复创建 patch"
    ]
  },
